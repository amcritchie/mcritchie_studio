#!/bin/bash
# /nfl-rebuild with start/end timing per step. Output to tmp/timed_rebuild.log.
# All timestamps in local time.

set -e
cd /Users/alex/projects/mcritchie_studio

LOG=tmp/timed_rebuild.log
echo "" > "$LOG"

stamp() { date '+%Y-%m-%d %H:%M:%S'; }

START_ALL=$(date +%s)
echo "═══ /nfl-rebuild START $(stamp) ═══" | tee -a "$LOG"
echo "" | tee -a "$LOG"

step() {
  local name="$1"; shift
  local t0=$(date +%s); local s0=$(stamp)
  echo "──[ $name ] start  $s0" | tee -a "$LOG"
  "$@" >> "$LOG" 2>&1
  local rc=$?
  local t1=$(date +%s); local s1=$(stamp)
  local dur=$((t1 - t0))
  echo "──[ $name ] end    $s1   (${dur}s)   exit=$rc" | tee -a "$LOG"
  echo "" | tee -a "$LOG"
  if [ $rc -ne 0 ]; then echo "ABORT: $name failed (rc=$rc)" | tee -a "$LOG"; exit $rc; fi
}

step "Step 1: db:drop+create+schema:load"   op run --env-file=/Users/alex/projects/.env -- bin/rails db:drop db:create db:schema:load
step "Step 2: db:seed"                       op run --env-file=/Users/alex/projects/.env -- bin/rails db:seed
step "Step 3: nfl:players_seed"              op run --env-file=/Users/alex/projects/.env -- bin/rails nfl:players_seed
step "Step 3.5: nfl:merge_duplicate_athletes" op run --env-file=/Users/alex/projects/.env -- bin/rails nfl:merge_duplicate_athletes DRY_RUN=0
step "Step 4: espn:scrape_depth_charts"      op run --env-file=/Users/alex/projects/.env -- bin/rails espn:scrape_depth_charts
step "Step 5a: nfl:upload_headshots"         op run --env-file=/Users/alex/projects/.env -- bin/rails nfl:upload_headshots
step "Step 5b: nfl:upload_coach_headshots"   op run --env-file=/Users/alex/projects/.env -- bin/rails nfl:upload_coach_headshots

END_ALL=$(date +%s)
TOTAL=$((END_ALL - START_ALL))
MIN=$((TOTAL / 60))
SEC=$((TOTAL % 60))

echo "═══ /nfl-rebuild END $(stamp) ═══" | tee -a "$LOG"
echo "TOTAL: ${TOTAL}s (${MIN}m ${SEC}s)" | tee -a "$LOG"
