#!/bin/bash
# Resume /nfl-rebuild from current state. Steps are idempotent.

set -e
cd /Users/alex/projects/mcritchie_studio
LOG=tmp/resume_rebuild.log
echo "" > "$LOG"
stamp() { date '+%Y-%m-%d %H:%M:%S'; }

START_ALL=$(date +%s)
echo "═══ resume START $(stamp) ═══" | tee -a "$LOG"

step() {
  local name="$1"; shift
  local t0=$(date +%s); local s0=$(stamp)
  echo "──[ $name ] start  $s0" | tee -a "$LOG"
  "$@" >> "$LOG" 2>&1
  local rc=$?
  local t1=$(date +%s); local s1=$(stamp)
  local dur=$((t1 - t0))
  echo "──[ $name ] end    $s1   (${dur}s)   exit=$rc" | tee -a "$LOG"
  if [ $rc -ne 0 ]; then echo "ABORT: $name failed (rc=$rc)" | tee -a "$LOG"; exit $rc; fi
}

step "Step 3 (resume): nfl:players_seed"           op run --env-file=/Users/alex/projects/.env -- bin/rails nfl:players_seed
step "Step 3.5: nfl:merge_duplicate_athletes"      op run --env-file=/Users/alex/projects/.env -- bin/rails nfl:merge_duplicate_athletes DRY_RUN=0
step "Step 4: espn:scrape_depth_charts"            op run --env-file=/Users/alex/projects/.env -- bin/rails espn:scrape_depth_charts
step "Step 5a: nfl:upload_headshots"               op run --env-file=/Users/alex/projects/.env -- bin/rails nfl:upload_headshots
step "Step 5b: nfl:upload_coach_headshots"         op run --env-file=/Users/alex/projects/.env -- bin/rails nfl:upload_coach_headshots
step "Step 5c: nfl:assign_grades"                  op run --env-file=/Users/alex/projects/.env -- bin/rails nfl:assign_grades

END_ALL=$(date +%s); TOTAL=$((END_ALL - START_ALL))
echo "═══ resume END $(stamp)   TOTAL ${TOTAL}s ($((TOTAL/60))m $((TOTAL%60))s) ═══" | tee -a "$LOG"
