<% stages = %w[new reviewed processed refined concluded archived] %>
<% stage_agents = { "new" => "Intake", "reviewed" => "Mason", "processed" => "Mack", "refined" => "Alex", "concluded" => "Turf Monster", "archived" => "Alex" } %>

<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.6/Sortable.min.js"></script>

<script>
function newsBoard() {
  return {
    _pendingMoves: {},
    showArchived: false,
    focusedStage: null,
    toasts: [],

    stageLabels: {
      new: 'New', reviewed: 'Reviewed', processed: 'Processed',
      refined: 'Refined', concluded: 'Concluded', archived: 'Archived'
    },

    init() {
      this.$nextTick(() => this.initSortables());
    },

    toggleFocus(stage) {
      this.focusedStage = this.focusedStage === stage ? null : stage;
      if (stage === 'archived') this.showArchived = true;
      this.$nextTick(() => this.initSortables());
    },

    initSortables() {
      document.querySelectorAll('.kanban-dropzone').forEach(zone => {
        Sortable.create(zone, {
          group: 'kanban',
          animation: 150,
          ghostClass: 'opacity-30',
          draggable: '.kanban-card',
          filter: '.kanban-empty',
          onEnd: (evt) => this.handleSortEnd(evt)
        });
      });
    },

    async handleSortEnd(evt) {
      const card = evt.item;
      const slug = card.dataset.slug;
      const oldStage = card.dataset.stage;
      const newZone = evt.to;
      const newStage = newZone.dataset.stage;
      const csrfToken = document.querySelector('meta[name="csrf-token"]')?.content;

      if (oldStage !== newStage) {
        card.dataset.stage = newStage;
        try {
          const resp = await fetch('/news/' + slug + '.json', {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
            body: JSON.stringify({ news: { stage: newStage } })
          });
          if (!resp.ok) {
            const err = await resp.json().catch(() => ({}));
            throw new Error(err.error || 'Failed (' + resp.status + ')');
          }
          this.showToast('Moved to ' + this.stageLabels[newStage], 'success');
        } catch (err) {
          const oldZone = document.getElementById('dropzone-' + oldStage);
          if (oldZone) {
            oldZone.insertBefore(card, oldZone.querySelector('.kanban-empty'));
            card.dataset.stage = oldStage;
          }
          card.classList.add('ring-2', 'ring-red-500');
          setTimeout(() => card.classList.remove('ring-2', 'ring-red-500'), 1500);
          this.showToast(err.message || 'Move failed', 'error');
          this.updateCounts();
          return;
        }
      }

      const slugs = Array.from(newZone.querySelectorAll('.kanban-card')).map(c => c.dataset.slug);
      try {
        await fetch('/news/reorder.json', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
          body: JSON.stringify({ slugs: slugs })
        });
      } catch (err) {}

      this.updateCounts();
    },

    updateCounts() {
      document.querySelectorAll('[data-stage-count]').forEach(badge => {
        const stage = badge.dataset.stageCount;
        const zone = document.getElementById('dropzone-' + stage);
        if (zone) {
          const count = zone.querySelectorAll('.kanban-card').length;
          badge.textContent = count;
          const empty = zone.querySelector('.kanban-empty');
          if (empty) empty.style.display = count === 0 ? 'flex' : 'none';
        }
      });
    },

    async archiveNews(slug) {
      if (this._pendingMoves[slug]) return;
      this._pendingMoves[slug] = true;

      const card = document.getElementById('card-' + slug);
      const oldStage = card?.dataset.stage;
      const archivedZone = document.getElementById('dropzone-archived');

      if (card && archivedZone) {
        archivedZone.insertBefore(card, archivedZone.querySelector('.kanban-empty'));
        card.dataset.stage = 'archived';
        this.updateCounts();
      }

      try {
        const csrfToken = document.querySelector('meta[name="csrf-token"]')?.content;
        const resp = await fetch('/news/' + slug + '/archive.json', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken }
        });
        if (!resp.ok) throw new Error('Archive failed');
        this.showToast('News archived', 'success');
      } catch (err) {
        if (card && oldStage) {
          const oldZone = document.getElementById('dropzone-' + oldStage);
          if (oldZone) {
            oldZone.insertBefore(card, oldZone.querySelector('.kanban-empty'));
            card.dataset.stage = oldStage;
            this.updateCounts();
          }
        }
        this.showToast(err.message, 'error');
      } finally {
        delete this._pendingMoves[slug];
      }
    },

    async deleteNews(slug) {
      if (!confirm('Delete this news item?')) return;
      if (this._pendingMoves[slug]) return;
      this._pendingMoves[slug] = true;

      const card = document.getElementById('card-' + slug);

      try {
        const csrfToken = document.querySelector('meta[name="csrf-token"]')?.content;
        const resp = await fetch('/news/' + slug + '.json', {
          method: 'DELETE',
          headers: { 'X-CSRF-Token': csrfToken }
        });
        if (!resp.ok) throw new Error('Delete failed');
        if (card) card.remove();
        this.updateCounts();
        this.showToast('News deleted', 'success');
      } catch (err) {
        this.showToast(err.message, 'error');
      } finally {
        delete this._pendingMoves[slug];
      }
    },

    showToast(message, type) {
      const id = Date.now();
      const toast = { id, message, type, visible: true };
      this.toasts.push(toast);
      setTimeout(() => {
        const t = this.toasts.find(t => t.id === id);
        if (t) t.visible = false;
        setTimeout(() => { this.toasts = this.toasts.filter(t => t.id !== id); }, 300);
      }, 3000);
    }
  }
}
</script>

<section x-data="newsBoard()" class="min-h-screen">
  <!-- Header -->
  <div class="flex items-center justify-between mb-6">
    <h2 class="text-2xl font-bold text-heading">News Pipeline</h2>
    <div class="flex items-center gap-3">
      <button @click="showArchived = !showArchived"
              :class="showArchived ? 'bg-primary text-white' : 'bg-surface text-secondary border border-subtle hover:text-heading'"
              class="px-3 py-2 rounded-lg text-sm font-medium transition">
        Archived
      </button>

      <% if logged_in? %>
        <%= link_to "New Article", new_news_path, class: "btn btn-primary" %>
      <% end %>
    </div>
  </div>

  <!-- Stage Progression -->
  <%= render "shared/pipeline_progression", highlight: "news" %>

  <!-- Kanban Board -->
  <div class="flex gap-4 overflow-x-auto pb-4">
    <% stages.each do |stage| %>
      <div class="min-w-[220px] transition-all duration-200"
           :class="focusedStage === '<%= stage %>' ? 'flex-[3]' : 'flex-1'"
           x-show="(!focusedStage || focusedStage === '<%= stage %>') && <%= stage == 'archived' ? "(showArchived || focusedStage === 'archived')" : 'true' %>"
           x-cloak>
        <!-- Column Header -->
        <div class="flex items-center justify-between mb-3 px-1 cursor-pointer" @click="toggleFocus('<%= stage %>')">
          <div class="flex items-center gap-2">
            <h3 class="text-sm font-bold text-heading uppercase tracking-wider hover:text-primary transition">
              <%= stage.humanize %>
            </h3>
            <span class="stage-count inline-flex items-center justify-center min-w-[20px] h-5 px-1.5 rounded-full text-xs font-bold
              <%= case stage
                  when 'new' then 'bg-blue-900/50 text-blue-300'
                  when 'reviewed' then 'bg-yellow-900/50 text-yellow-300'
                  when 'processed' then 'bg-mint-900/50 text-mint-300'
                  when 'refined' then 'bg-green-900/50 text-green-300'
                  when 'concluded' then 'bg-violet-900/50 text-violet-300'
                  when 'archived' then 'bg-surface-alt text-muted'
                  end %>"
              data-stage-count="<%= stage %>">
              <%= (@news_by_stage[stage] || []).size %>
            </span>
          </div>
          <span class="text-[10px] text-muted"><%= stage_agents[stage] %></span>
        </div>

        <!-- Drop Zone -->
        <div id="dropzone-<%= stage %>"
             data-stage="<%= stage %>"
             class="kanban-dropzone rounded-xl border-2 border-dashed min-h-[calc(100vh-220px)] p-2 space-y-2 transition-colors duration-150 border-subtle">

          <% (@news_by_stage[stage] || []).each_with_index do |news, idx| %>
            <div id="card-<%= news.slug %>"
                 data-slug="<%= news.slug %>"
                 data-stage="<%= stage %>"
                 class="kanban-card bg-surface rounded-lg border border-subtle p-3 cursor-grab active:cursor-grabbing hover:border-primary/30 transition group relative">

              <span class="absolute top-1 right-1.5 text-[9px] text-muted font-mono"><%= news.position %></span>

              <div class="flex items-center justify-between mb-1.5">
                <a href="<%= news_path(news.slug) %>"
                   class="text-heading font-semibold text-sm truncate flex-1 hover:text-primary transition"
                   @click.stop>
                  <%= news.title_short.presence || news.title %>
                </a>
                <div class="flex items-center gap-1 ml-2 opacity-0 group-hover:opacity-100 transition-opacity shrink-0">
                  <% if news.stage != 'archived' %>
                    <button @click.stop="archiveNews('<%= news.slug %>')"
                            class="text-muted hover:text-yellow-400 transition p-0.5" title="Archive">
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/>
                      </svg>
                    </button>
                  <% end %>
                  <button @click.stop="deleteNews('<%= news.slug %>')"
                          class="text-muted hover:text-red-400 transition p-0.5" title="Delete">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                    </svg>
                  </button>
                </div>
              </div>

              <!-- Metadata -->
              <div class="flex flex-wrap items-center gap-1.5 mb-1">
                <% if news.author.present? %>
                  <span class="text-[10px] text-muted"><%= news.author %></span>
                <% end %>
                <% if news.primary_person.present? %>
                  <span class="px-1.5 py-0.5 rounded text-[10px] font-bold bg-blue-900/50 text-blue-300 border border-blue-700/50"><%= news.primary_person %></span>
                <% end %>
                <% if news.primary_team.present? %>
                  <span class="px-1.5 py-0.5 rounded text-[10px] font-bold bg-green-900/50 text-green-300 border border-green-700/50"><%= news.primary_team %></span>
                <% end %>
              </div>

              <% if news.feeling_emoji.present? %>
                <span class="text-sm"><%= news.feeling_emoji %></span>
              <% end %>

              <% if news.primary_action.present? || news.what_happened.present? %>
                <p class="text-[10px] text-secondary truncate"><%= news.what_happened.presence || news.primary_action %></p>
              <% end %>

              <p class="text-[10px] text-muted mt-1"><%= time_ago_in_words(news.created_at) %> ago</p>
            </div>
          <% end %>

          <!-- Empty State -->
          <div class="kanban-empty flex items-center justify-center h-24 text-muted text-sm"
               <% if (@news_by_stage[stage] || []).any? %>style="display: none"<% end %>>
            Drop news here
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Toasts -->
  <div class="fixed top-4 right-4 z-50 space-y-2">
    <template x-for="toast in toasts" :key="toast.id">
      <div x-show="toast.visible"
           x-transition:enter="transition ease-out duration-300"
           x-transition:enter-start="opacity-0 translate-x-8"
           x-transition:enter-end="opacity-100 translate-x-0"
           x-transition:leave="transition ease-in duration-200"
           x-transition:leave-start="opacity-100 translate-x-0"
           x-transition:leave-end="opacity-0 translate-x-8"
           :class="toast.type === 'success' ? 'bg-mint-900/90 border-mint-700 text-mint-300' : 'bg-red-900/90 border-red-700 text-red-300'"
           class="px-4 py-2.5 rounded-lg border text-sm font-medium shadow-lg backdrop-blur-sm">
        <span x-text="toast.message"></span>
      </div>
    </template>
  </div>
</section>
