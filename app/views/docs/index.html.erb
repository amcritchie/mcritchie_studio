<div class="mb-6">
  <h2 class="text-2xl font-bold text-heading">Agent Docs</h2>
  <p class="text-secondary text-sm mt-1">System documentation for the McRitchie agent network</p>
</div>

<!-- System -->
<div class="mb-8">
  <h3 class="text-lg font-semibold text-heading mb-3">System</h3>
  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
    <% @system_docs.each do |doc| %>
      <%= link_to doc_path(doc[:path]), class: "block card p-4 hover:border-violet/40 transition" do %>
        <span class="text-heading font-medium text-sm"><%= doc[:name].titleize %></span>
      <% end %>
    <% end %>
  </div>
</div>

<!-- Agents -->
<div class="mb-8">
  <h3 class="text-lg font-semibold text-heading mb-3">Agents</h3>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
    <% @agent_docs.each do |agent| %>
      <div class="card p-4">
        <h4 class="text-heading font-semibold text-sm mb-3 capitalize"><%= agent[:name].tr("_", " ") %></h4>
        <div class="flex flex-col gap-2">
          <% agent[:docs].each do |doc| %>
            <%= link_to doc[:name].titleize, doc_path(doc[:path]), class: "text-violet hover:text-violet-300 text-sm font-medium transition" %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<!-- Shared -->
<% if @shared_docs.any? %>
  <div class="mb-8">
    <h3 class="text-lg font-semibold text-heading mb-3">Shared</h3>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
      <% @shared_docs.each do |doc| %>
        <%= link_to doc_path(doc[:path]), class: "block card p-4 hover:border-violet/40 transition" do %>
          <span class="text-heading font-medium text-sm"><%= doc[:name].titleize %></span>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>
