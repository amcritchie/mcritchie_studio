<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.6/Sortable.min.js"></script>

<style>
  .dc-entry { transition: background-color 0.15s ease; }
  .dc-entry.dc-locked { background: rgba(255, 215, 0, 0.06); }
  .dc-entry.dc-locked .dc-handle { cursor: not-allowed; opacity: 0.4; }
  .dc-handle { cursor: grab; }
  .dc-handle:active { cursor: grabbing; }
  .sortable-ghost { opacity: 0.3; }
</style>

<section class="max-w-6xl mx-auto px-4 py-8" x-data='depthChart("<%= reorder_depth_chart_path(@team.slug) %>")'>
  <div class="mb-6 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <% if @team.color_primary.present? %>
        <span class="inline-block w-4 h-4 rounded-full" style="background-color: <%= @team.color_primary %>"></span>
      <% end %>
      <h1 class="text-3xl font-bold text-heading"><%= @team.emoji %> <%= @team.name %> — Depth Chart</h1>
    </div>
    <%= link_to "← All Rosters", nfl_rosters_path, class: "text-secondary hover:text-primary text-sm" %>
  </div>

  <p class="text-secondary text-sm mb-6">
    Drag rows within a position to reorder depth. Click the lock icon to pin an entry — locked rows hold their depth across re-seeds.
  </p>

  <% %w[offense defense special_teams].each do |side| %>
    <% groups = @entries_by_side[side] || {} %>
    <% next if groups.empty? %>
    <h2 class="text-xl font-bold text-heading mt-8 mb-3 capitalize"><%= side.tr("_", " ") %></h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <% groups.each do |position, entries| %>
        <div class="card p-3">
          <div class="flex items-center justify-between mb-2">
            <h3 class="font-semibold text-heading text-sm"><%= position %></h3>
            <span class="text-muted text-xs"><%= entries.size %></span>
          </div>
          <ul class="dc-zone space-y-1" data-position="<%= position %>">
            <% entries.each do |entry| %>
              <% person  = entry.person %>
              <% athlete = person.athlete_profile %>
              <% small   = athlete&.headshot_url(width: 100) %>
              <% grade   = @grades_by_person[entry.person_slug] %>
              <li class="dc-entry <%= 'dc-locked' if entry.locked %> flex items-center gap-2 px-2 py-1.5 bg-surface rounded border border-subtle"
                  data-id="<%= entry.id %>"
                  data-locked="<%= entry.locked %>">
                <span class="dc-handle text-muted text-xs w-4 select-none">⋮⋮</span>
                <span class="text-muted text-xs font-mono w-5"><%= entry.depth %></span>
                <% if small %>
                  <img src="<%= small %>" alt="<%= person.full_name %>" loading="lazy"
                       class="w-7 h-7 rounded-full object-cover bg-surface-alt flex-shrink-0">
                <% else %>
                  <div class="w-7 h-7 rounded-full bg-surface-alt flex-shrink-0"></div>
                <% end %>
                <span class="text-body text-sm flex-1 truncate"><%= person.full_name %></span>
                <% if grade&.overall_grade %>
                  <span class="text-xs font-mono text-secondary"><%= grade.overall_grade %></span>
                <% end %>
                <button type="button"
                        @click="toggleLock(<%= entry.id %>, $event.currentTarget)"
                        class="text-muted hover:text-primary text-base px-1"
                        title="<%= entry.locked ? 'Unlock' : 'Lock' %>">
                  <span x-text="$el.dataset.label"
                        data-label="<%= entry.locked ? '🔒' : '🔓' %>"></span>
                </button>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>
    </div>
  <% end %>
</section>

