<div class="card p-6">
  <% if task.errors.any? %>
    <div class="mb-4 p-3 bg-red-900/50 border border-red-700 rounded-lg text-red-300 text-sm">
      <% task.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <%= form_with model: task, url: task.persisted? ? task_path(task.slug) : tasks_path do |f| %>
    <div class="mb-5">
      <label class="block text-sm text-secondary mb-2 font-medium">Title</label>
      <%= f.text_field :title, class: "input-field", placeholder: "Task title" %>
    </div>

    <div class="mb-5">
      <label class="block text-sm text-secondary mb-2 font-medium">Description</label>
      <%= f.text_area :description, rows: 4, class: "input-field", placeholder: "What needs to be done?" %>
    </div>

    <div class="grid grid-cols-2 gap-4 mb-5">
      <div>
        <label class="block text-sm text-secondary mb-2 font-medium">Priority</label>
        <%= f.select :priority, [["Normal (0)", 0], ["High (1)", 1], ["Critical (2)", 2]], {}, class: "input-field" %>
      </div>
      <div>
        <label class="block text-sm text-secondary mb-2 font-medium">Assign to Agent</label>
        <%= f.select :agent_slug, @agents.map { |a| [a.name, a.slug] }, { include_blank: "Unassigned" }, class: "input-field" %>
      </div>
    </div>

    <button type="submit" class="btn btn-primary btn-lg">
      <%= task.persisted? ? "Update Task" : "Create Task" %>
    </button>
  <% end %>
</div>
