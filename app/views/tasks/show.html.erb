<section>
  <div class="mb-6 flex items-center justify-between">
    <%= link_to "&larr; All Tasks".html_safe, tasks_path, class: "text-secondary hover:text-heading text-sm transition" %>
    <% if logged_in? %>
      <%= link_to "Edit", edit_task_path(@task.slug), class: "btn btn-outline btn-sm" %>
    <% end %>
  </div>

  <div class="card p-6 mb-6">
    <div class="flex items-start justify-between mb-4">
      <div>
        <h2 class="text-2xl font-bold text-heading"><%= @task.title %></h2>
        <div class="flex items-center gap-3 mt-2">
          <%= render "components/badge", text: @task.stage.humanize, scheme: stage_scheme(@task.stage) %>
          <% if @task.priority > 0 %>
            <span class="text-xs text-yellow-400 font-medium">Priority <%= @task.priority %></span>
          <% end %>
          <% if @task.agent_slug.present? %>
            <%= link_to @task.agent_slug, agent_path(@task.agent_slug), class: "text-xs text-primary hover:text-primary-300" %>
          <% end %>
        </div>
      </div>
      <span class="text-xs text-muted font-mono"><%= @task.slug %></span>
    </div>

    <% if @task.description.present? %>
      <div class="mb-4">
        <p class="text-body text-sm whitespace-pre-wrap"><%= @task.description %></p>
      </div>
    <% end %>

    <!-- Timestamps -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-4">
      <div class="bg-surface-alt rounded-lg p-3">
        <p class="label-upper">Created</p>
        <p class="text-heading text-sm"><%= @task.created_at.strftime("%b %d, %H:%M") %></p>
      </div>
      <% if @task.queued_at %>
        <div class="bg-surface-alt rounded-lg p-3">
          <p class="label-upper">Queued</p>
          <p class="text-heading text-sm"><%= @task.queued_at.strftime("%b %d, %H:%M") %></p>
        </div>
      <% end %>
      <% if @task.started_at %>
        <div class="bg-surface-alt rounded-lg p-3">
          <p class="label-upper">Started</p>
          <p class="text-heading text-sm"><%= @task.started_at.strftime("%b %d, %H:%M") %></p>
        </div>
      <% end %>
      <% if @task.completed_at %>
        <div class="bg-surface-alt rounded-lg p-3">
          <p class="label-upper">Completed</p>
          <p class="text-heading text-sm"><%= @task.completed_at.strftime("%b %d, %H:%M") %></p>
        </div>
      <% end %>
    </div>

    <% if @task.error_message.present? %>
      <div class="bg-red-900/30 border border-red-700/50 rounded-lg p-3 mb-4">
        <p class="text-xs text-red-400 uppercase tracking-wider mb-1">Error</p>
        <p class="text-red-300 text-sm"><%= @task.error_message %></p>
      </div>
    <% end %>
  </div>

  <!-- Stage Transition Buttons -->
  <% if logged_in? %>
    <div class="flex flex-wrap gap-2">
      <% case @task.stage %>
      <% when "new" %>
        <%= button_to "Queue", queue_task_path(@task.slug), class: "btn btn-warning" %>
      <% when "queued" %>
        <%= button_to "Start", start_task_path(@task.slug), class: "btn btn-secondary" %>
      <% when "in_progress" %>
        <%= button_to "Complete", complete_task_path(@task.slug), class: "btn btn-success" %>
        <%= button_to "Fail", fail_task_task_path(@task.slug), class: "btn btn-danger" %>
      <% end %>
      <% unless @task.stage == "archived" %>
        <%= button_to "Archive", archive_task_path(@task.slug), class: "btn bg-surface-alt text-body hover:bg-inset" %>
      <% end %>
    </div>
  <% end %>
</section>
