<section>
  <div class="mb-6 flex items-center justify-between">
    <%= link_to "&larr; All Tasks".html_safe, tasks_path, class: "text-gray-400 hover:text-white text-sm transition" %>
    <% if logged_in? %>
      <%= link_to "Edit", edit_task_path(@task.slug), class: "px-3 py-1.5 bg-navy-400 text-gray-300 hover:text-white text-sm rounded-lg border border-navy-300/20 transition" %>
    <% end %>
  </div>

  <div class="bg-navy-400 rounded-xl border border-navy-300/20 p-6 mb-6">
    <div class="flex items-start justify-between mb-4">
      <div>
        <h2 class="text-2xl font-bold text-white"><%= @task.title %></h2>
        <div class="flex items-center gap-3 mt-2">
          <span class="inline-flex px-2 py-0.5 rounded text-xs font-medium
            <%= case @task.stage
                when 'new' then 'bg-blue-900/30 text-blue-300 border border-blue-700/50'
                when 'queued' then 'bg-yellow-900/30 text-yellow-300 border border-yellow-700/50'
                when 'in_progress' then 'bg-mint-900/30 text-mint-300 border border-mint-700/50'
                when 'done' then 'bg-green-900/30 text-green-300 border border-green-700/50'
                when 'failed' then 'bg-red-900/30 text-red-300 border border-red-700/50'
                else 'bg-gray-900/30 text-gray-300 border border-gray-700/50'
                end %>"><%= @task.stage.humanize %></span>
          <% if @task.priority > 0 %>
            <span class="text-xs text-yellow-400 font-medium">Priority <%= @task.priority %></span>
          <% end %>
          <% if @task.agent_slug.present? %>
            <%= link_to @task.agent_slug, agent_path(@task.agent_slug), class: "text-xs text-violet hover:text-violet-300" %>
          <% end %>
        </div>
      </div>
      <span class="text-xs text-gray-600 font-mono"><%= @task.slug %></span>
    </div>

    <% if @task.description.present? %>
      <div class="mb-4">
        <p class="text-gray-300 text-sm whitespace-pre-wrap"><%= @task.description %></p>
      </div>
    <% end %>

    <!-- Timestamps -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-4">
      <div class="bg-navy-600 rounded-lg p-3">
        <p class="text-xs text-gray-500 uppercase tracking-wider">Created</p>
        <p class="text-white text-sm"><%= @task.created_at.strftime("%b %d, %H:%M") %></p>
      </div>
      <% if @task.queued_at %>
        <div class="bg-navy-600 rounded-lg p-3">
          <p class="text-xs text-gray-500 uppercase tracking-wider">Queued</p>
          <p class="text-white text-sm"><%= @task.queued_at.strftime("%b %d, %H:%M") %></p>
        </div>
      <% end %>
      <% if @task.started_at %>
        <div class="bg-navy-600 rounded-lg p-3">
          <p class="text-xs text-gray-500 uppercase tracking-wider">Started</p>
          <p class="text-white text-sm"><%= @task.started_at.strftime("%b %d, %H:%M") %></p>
        </div>
      <% end %>
      <% if @task.completed_at %>
        <div class="bg-navy-600 rounded-lg p-3">
          <p class="text-xs text-gray-500 uppercase tracking-wider">Completed</p>
          <p class="text-white text-sm"><%= @task.completed_at.strftime("%b %d, %H:%M") %></p>
        </div>
      <% end %>
    </div>

    <% if @task.error_message.present? %>
      <div class="bg-red-900/30 border border-red-700/50 rounded-lg p-3 mb-4">
        <p class="text-xs text-red-400 uppercase tracking-wider mb-1">Error</p>
        <p class="text-red-300 text-sm"><%= @task.error_message %></p>
      </div>
    <% end %>
  </div>

  <!-- Stage Transition Buttons -->
  <% if logged_in? %>
    <div class="flex flex-wrap gap-2">
      <% case @task.stage %>
      <% when "new" %>
        <%= button_to "Queue", queue_task_path(@task.slug), class: "px-4 py-2 bg-yellow-600 hover:bg-yellow-500 text-white text-sm font-bold rounded-lg transition" %>
      <% when "queued" %>
        <%= button_to "Start", start_task_path(@task.slug), class: "px-4 py-2 bg-mint hover:bg-mint-600 text-navy text-sm font-bold rounded-lg transition" %>
      <% when "in_progress" %>
        <%= button_to "Complete", complete_task_path(@task.slug), class: "px-4 py-2 bg-green-600 hover:bg-green-500 text-white text-sm font-bold rounded-lg transition" %>
        <%= button_to "Fail", fail_task_task_path(@task.slug), class: "px-4 py-2 bg-red-600 hover:bg-red-500 text-white text-sm font-bold rounded-lg transition" %>
      <% end %>
      <% unless @task.stage == "archived" %>
        <%= button_to "Archive", archive_task_path(@task.slug), class: "px-4 py-2 bg-gray-600 hover:bg-gray-500 text-white text-sm font-bold rounded-lg transition" %>
      <% end %>
    </div>
  <% end %>
</section>
