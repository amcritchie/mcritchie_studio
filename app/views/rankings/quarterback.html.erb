<% content_for :title, "NFL Quarterback Rankings — 2025 Season" %>
<% content_for :full_width, true %>

<section class="py-6 px-4">
  <div class="max-w-5xl mx-auto">
    <%= link_to nfl_hub_path, class: "inline-flex items-center gap-1 text-sm text-secondary hover:text-heading transition mb-4" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      NFL Hub
    <% end %>

    <%# Hero %>
    <div class="rounded-xl overflow-hidden mb-8" style="background: linear-gradient(135deg, var(--color-cta), var(--color-cta-hover));">
      <div class="py-8 px-6 text-center">
        <span class="text-4xl block mb-2">🏈</span>
        <h1 class="text-2xl md:text-3xl font-extrabold text-white">Quarterback Rankings</h1>
        <p class="text-white/70 text-sm mt-1">2025 NFL Season</p>
      </div>
    </div>

    <%# Search + sort controls %>
    <div class="card p-4 mb-6">
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div class="flex-1 max-w-sm">
          <form method="get" action="<%= nfl_quarterback_rankings_path %>">
            <input type="hidden" name="sort" value="<%= @sort_by %>">
            <div class="relative">
              <input type="text" name="search" value="<%= params[:search] %>"
                     placeholder="Search players, teams..."
                     class="input-field w-full pl-10 pr-4 py-2 text-sm">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <svg class="h-4 w-4 text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
              </div>
            </div>
          </form>
        </div>

        <div class="flex gap-2">
          <% %w[overall passing rushing].each do |sort| %>
            <%= link_to sort.capitalize,
                  nfl_quarterback_rankings_path(sort: sort, search: params[:search]),
                  class: "px-4 py-2 rounded-lg text-sm font-semibold transition #{@sort_by == sort ? 'btn btn-primary' : 'bg-surface-alt text-secondary hover:text-heading'}" %>
          <% end %>
        </div>
      </div>
    </div>

    <%# Rankings table %>
    <div class="card overflow-hidden">
      <div class="px-5 py-3 border-b border-subtle flex items-center gap-2">
        <span class="text-lg">🏈</span>
        <h2 class="font-bold text-heading text-sm">Quarterback Rankings</h2>
        <span class="text-xs text-muted ml-auto"><%= @players.size %> players</span>
      </div>

      <% if @players.any? %>
        <div class="overflow-x-auto">
          <table class="min-w-full">
            <thead>
              <tr class="bg-surface-alt text-xs text-muted uppercase tracking-wider">
                <th class="px-3 py-2 text-center w-12">#</th>
                <th class="px-3 py-2 text-center w-12"></th>
                <th class="px-3 py-2 text-left">Player</th>
                <th class="hidden md:table-cell px-3 py-2 text-left">Team</th>
                <th class="px-3 py-2 text-center">Grade</th>
                <th class="hidden md:table-cell px-3 py-2 text-center">Pass</th>
                <th class="hidden md:table-cell px-3 py-2 text-center">Rush</th>
                <th class="hidden md:table-cell px-3 py-2 text-center">GP</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-subtle">
              <% @players.each_with_index do |p, i| %>
                <tr class="hover:bg-surface-alt transition-colors"
                    data-search="<%= "#{p.first_name} #{p.last_name} #{p.team_name}".downcase %>">
                  <td class="px-3 py-3 text-center">
                    <span class="inline-flex items-center justify-center w-7 h-7 rounded-full text-xs font-bold text-white" style="background: var(--color-cta);">
                      <%= i + 1 %>
                    </span>
                  </td>
                  <td class="px-3 py-3 text-center text-lg">
                    <%= p.team_emoji || '🏈' %>
                  </td>
                  <td class="px-3 py-3">
                    <p class="font-bold text-heading text-sm"><%= p.first_name %> <%= p.last_name %></p>
                    <p class="text-xs text-muted md:hidden"><%= p.team_short_name || p.team_name %></p>
                  </td>
                  <td class="hidden md:table-cell px-3 py-3">
                    <span class="badge"><%= p.team_short_name || p.team_name || "—" %></span>
                  </td>
                  <td class="px-3 py-3 text-center">
                    <% grade = p.overall_grade_pff %>
                    <% if grade %>
                      <span class="text-sm font-bold rounded px-1.5 py-0.5 text-white" style="background: <%= grade_color(grade) %>;">
                        <%= grade.round(1) %>
                      </span>
                    <% end %>
                  </td>
                  <td class="hidden md:table-cell px-3 py-3 text-center">
                    <% pg = p.pass_grade_pff %>
                    <% if pg %>
                      <span class="text-xs font-semibold" style="color: <%= grade_color(pg) %>;"><%= pg.round(1) %></span>
                    <% else %>
                      <span class="text-xs text-muted">—</span>
                    <% end %>
                  </td>
                  <td class="hidden md:table-cell px-3 py-3 text-center">
                    <% rg = p.run_grade_pff %>
                    <% if rg %>
                      <span class="text-xs font-semibold" style="color: <%= grade_color(rg) %>;"><%= rg.round(1) %></span>
                    <% else %>
                      <span class="text-xs text-muted">—</span>
                    <% end %>
                  </td>
                  <td class="hidden md:table-cell px-3 py-3 text-center text-xs text-muted">
                    <%= p.games_played || "—" %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="text-center py-12">
          <p class="text-muted">No quarterback data available.</p>
        </div>
      <% end %>
    </div>
  </div>
</section>
