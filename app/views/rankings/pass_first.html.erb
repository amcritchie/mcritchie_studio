<% content_for :title, "Pass-First Rankings — 2025 NFL Season" %>
<% content_for :full_width, true %>

<section class="py-6 px-4">
  <div class="max-w-5xl mx-auto">
    <%= link_to nfl_hub_path, class: "inline-flex items-center gap-1 text-sm text-secondary hover:text-heading transition mb-4" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      NFL Hub
    <% end %>

    <%# Hero %>
    <div class="rounded-xl overflow-hidden mb-8" style="background: linear-gradient(135deg, var(--color-cta), var(--color-cta-hover));">
      <div class="py-8 px-6 text-center">
        <span class="text-4xl block mb-2">✈️</span>
        <h1 class="text-2xl md:text-3xl font-extrabold text-white">Pass-First Rankings</h1>
        <p class="text-white/70 text-sm mt-1">2025 NFL Season</p>
      </div>
    </div>

    <%# Search + sort controls %>
    <div class="card p-4 mb-6">
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div class="flex-1 max-w-sm">
          <form method="get" action="<%= nfl_pass_first_rankings_path %>">
            <input type="hidden" name="sort" value="<%= @sort_by %>">
            <div class="relative">
              <input type="text" name="search" value="<%= params[:search] %>"
                     placeholder="Search coaches, teams..."
                     class="input-field w-full pl-10 pr-4 py-2 text-sm">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <svg class="h-4 w-4 text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
              </div>
            </div>
          </form>
        </div>

        <div class="flex gap-2">
          <% { "pass_first" => "Pass First", "pass_heavy" => "Pass Heavy" }.each do |key, label| %>
            <%= link_to label,
                  nfl_pass_first_rankings_path(sort: key, search: params[:search]),
                  class: "px-4 py-2 rounded-lg text-sm font-semibold transition #{@sort_by == key ? 'btn btn-primary' : 'bg-surface-alt text-secondary hover:text-heading'}" %>
          <% end %>
        </div>
      </div>
    </div>

    <%# Rankings table %>
    <div class="card overflow-hidden">
      <div class="px-5 py-3 border-b border-subtle flex items-center gap-2">
        <span class="text-lg"><%= @sort_by == "pass_heavy" ? "📊" : "✈️" %></span>
        <h2 class="font-bold text-heading text-sm"><%= @sort_by == "pass_heavy" ? "Pass-Heavy Rankings" : "Pass-First Rankings" %></h2>
        <span class="text-xs text-muted ml-auto"><%= @rankings.size %> coaches</span>
      </div>

      <% if @rankings.any? %>
        <div class="overflow-x-auto">
          <table class="min-w-full">
            <thead>
              <tr class="bg-surface-alt text-xs text-muted uppercase tracking-wider">
                <th class="px-3 py-2 text-center w-12">#</th>
                <th class="px-3 py-2 text-center w-12"></th>
                <th class="px-3 py-2 text-left">Coach</th>
                <th class="px-3 py-2 text-left">Team</th>
                <th class="px-3 py-2 text-center">Rank</th>
                <th class="px-3 py-2 text-center">Tier</th>
                <th class="hidden md:table-cell px-3 py-2 text-center">Lean</th>
                <th class="hidden md:table-cell px-3 py-2 text-center">Conf/Div</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-subtle">
              <% @rankings.each_with_index do |r, i| %>
                <tr class="hover:bg-surface-alt transition-colors">
                  <td class="px-3 py-3 text-center">
                    <span class="text-xs font-bold text-muted"><%= i + 1 %></span>
                  </td>
                  <td class="px-3 py-3 text-center text-lg">
                    <%= r.team_emoji || '🏈' %>
                  </td>
                  <td class="px-3 py-3">
                    <p class="font-bold text-heading text-sm"><%= r.first_name %> <%= r.last_name %></p>
                  </td>
                  <td class="px-3 py-3">
                    <span class="badge"><%= r.team_short_name || r.team_name || "—" %></span>
                  </td>
                  <td class="px-3 py-3 text-center">
                    <span class="text-sm font-bold text-heading"><%= r.rank %></span>
                  </td>
                  <td class="px-3 py-3 text-center">
                    <span class="text-xs font-semibold px-2 py-0.5 rounded-full <%= tier_badge_class(r.tier) %>">
                      <%= tier_emoji(r.tier) %> <%= r.tier %>
                    </span>
                  </td>
                  <td class="hidden md:table-cell px-3 py-3 text-center">
                    <% if r.lean.present? %>
                      <span class="text-xs font-semibold <%= r.lean == 'offense' ? 'text-green-400' : 'text-red-400' %>"><%= r.lean.capitalize %></span>
                    <% else %>
                      <span class="text-xs text-muted">—</span>
                    <% end %>
                  </td>
                  <td class="hidden md:table-cell px-3 py-3 text-center text-xs text-muted">
                    <%= r.conference %> <%= r.division %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="text-center py-12">
          <p class="text-muted">No pass-first ranking data available.</p>
        </div>
      <% end %>
    </div>
  </div>
</section>
