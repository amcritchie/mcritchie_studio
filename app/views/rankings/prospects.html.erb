<% content_for :title, "#{@draft_year} NFL Draft Prospects" %>
<% content_for :full_width, true %>

<section class="py-6 px-4">
  <div class="max-w-6xl mx-auto">
    <%= link_to nfl_hub_path, class: "inline-flex items-center gap-1 text-sm text-secondary hover:text-heading transition mb-4" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      NFL Hub
    <% end %>

    <%# Hero %>
    <div class="rounded-xl overflow-hidden mb-8" style="background: linear-gradient(135deg, var(--color-cta), var(--color-cta-hover));">
      <div class="py-8 px-6 text-center">
        <span class="text-4xl block mb-2">🎓</span>
        <h1 class="text-2xl md:text-3xl font-extrabold text-white"><%= @draft_year %> NFL Draft Prospects</h1>
        <p class="text-white/70 text-sm mt-1">
          <% if @draft_year == 2026 %>
            Mock draft projections
          <% else %>
            Scouting grades with projected ranges
          <% end %>
        </p>
      </div>
    </div>

    <%# Year toggle + Search + sort controls %>
    <div class="card p-4 mb-6">
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div class="flex gap-2">
          <% [2025, 2026].each do |year| %>
            <%= link_to year,
                  nfl_prospects_path(year: year),
                  class: "px-4 py-2 rounded-lg text-sm font-bold transition #{@draft_year == year ? 'btn btn-primary' : 'bg-surface-alt text-secondary hover:text-heading'}" %>
          <% end %>
        </div>

        <div class="flex-1 max-w-sm">
          <form method="get" action="<%= nfl_prospects_path %>">
            <input type="hidden" name="sort" value="<%= @sort_by %>">
            <input type="hidden" name="year" value="<%= @draft_year %>">
            <div class="relative">
              <input type="text" name="search" value="<%= params[:search] %>"
                     placeholder="Search players, teams, positions..."
                     class="input-field w-full pl-10 pr-4 py-2 text-sm">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <svg class="h-4 w-4 text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
              </div>
            </div>
          </form>
        </div>

        <div class="flex gap-2">
          <% %w[pick grade position].each do |sort| %>
            <%= link_to sort.capitalize,
                  nfl_prospects_path(sort: sort, search: params[:search], year: @draft_year),
                  class: "px-4 py-2 rounded-lg text-sm font-semibold transition #{@sort_by == sort ? 'btn btn-primary' : 'bg-surface-alt text-secondary hover:text-heading'}" %>
          <% end %>
        </div>
      </div>
    </div>

    <%# Prospects table %>
    <div class="card overflow-hidden">
      <div class="px-5 py-3 border-b border-subtle flex items-center gap-2">
        <span class="text-lg">🎓</span>
        <h2 class="font-bold text-heading text-sm">Draft Prospects</h2>
        <span class="text-xs text-muted ml-auto"><%= @prospects.size %> prospects</span>
      </div>

      <% if @prospects.any? %>
        <div class="overflow-x-auto">
          <table class="min-w-full">
            <thead>
              <tr class="bg-surface-alt text-xs text-muted uppercase tracking-wider">
                <th class="px-3 py-2 text-center w-14">Pick</th>
                <th class="px-3 py-2 text-center w-12"></th>
                <th class="px-3 py-2 text-left">Player</th>
                <th class="px-3 py-2 text-center w-14">Pos</th>
                <th class="hidden md:table-cell px-3 py-2 text-left">Team</th>
                <th class="px-3 py-2 text-center">Grade</th>
                <th class="hidden md:table-cell px-3 py-2 text-center">Primary</th>
                <th class="hidden lg:table-cell px-3 py-2 text-center">Secondary</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-subtle">
              <% @prospects.each do |p| %>
                <%
                  pick = p.draft_pick
                  round = p.draft_round
                  round_color = case round
                                when 1 then "#16a34a"
                                when 2 then "#eab308"
                                else "#6b7280"
                                end
                  ranges = p.grade_ranges || {}
                  pos = p.position

                  # Determine primary/secondary grade columns and labels
                  case pos
                  when "QB"
                    primary_key = "pass_grade"; primary_label = "Pass"
                    secondary_key = "run_grade"; secondary_label = "Rush"
                  when "WR", "TE", "CB/WR"
                    primary_key = "pass_route_grade"; primary_label = "Route"
                    secondary_key = "run_grade"; secondary_label = "Run"
                  when "RB", "FB", "HB"
                    primary_key = "run_grade"; primary_label = "Rush"
                    secondary_key = "pass_route_grade"; secondary_label = "Route"
                  when "OT", "OG", "C"
                    primary_key = "pass_block_grade"; primary_label = "Pass Blk"
                    secondary_key = "run_block_grade"; secondary_label = "Run Blk"
                  when "EDGE", "DE"
                    primary_key = "pass_rush_grade"; primary_label = "Pass Rush"
                    secondary_key = "rush_defense_grade"; secondary_label = "Run Def"
                  when "DT", "NT", "DL"
                    primary_key = "rush_defense_grade"; primary_label = "Run Def"
                    secondary_key = "pass_rush_grade"; secondary_label = "Pass Rush"
                  when "LB", "ILB", "OLB", "MLB"
                    primary_key = "rush_defense_grade"; primary_label = "Run Def"
                    secondary_key = "coverage_grade"; secondary_label = "Coverage"
                  when "CB"
                    primary_key = "coverage_grade"; primary_label = "Coverage"
                    secondary_key = "rush_defense_grade"; secondary_label = "Run Def"
                  when "S", "FS", "SS"
                    primary_key = "coverage_grade"; primary_label = "Coverage"
                    secondary_key = "rush_defense_grade"; secondary_label = "Run Def"
                  else
                    primary_key = nil; primary_label = nil
                    secondary_key = nil; secondary_label = nil
                  end

                  primary_val = primary_key ? p.send(primary_key) : nil
                  secondary_val = secondary_key ? p.send(secondary_key) : nil
                  primary_range = ranges[primary_key]
                  secondary_range = ranges[secondary_key]
                  overall_range = ranges["overall_grade"]
                %>
                <tr class="hover:bg-surface-alt transition-colors cursor-pointer"
                    onclick="window.location='<%= nfl_player_impact_path(player_id: p.person_slug_ref, team_id: p.team_slug_ref) %>'">
                  <td class="px-3 py-3 text-center">
                    <span class="inline-flex items-center justify-center w-8 h-6 rounded text-xs font-bold text-white" style="background: <%= round_color %>;">
                      #<%= pick %>
                    </span>
                  </td>
                  <td class="px-3 py-3 text-center text-lg">
                    <%= p.team_emoji || '🏈' %>
                  </td>
                  <td class="px-3 py-3">
                    <p class="font-bold text-heading text-sm"><%= p.first_name %> <%= p.last_name %></p>
                    <p class="text-xs text-muted md:hidden"><%= p.team_short_name || p.team_name %></p>
                  </td>
                  <td class="px-3 py-3 text-center">
                    <span class="badge text-xs"><%= pos %></span>
                  </td>
                  <td class="hidden md:table-cell px-3 py-3">
                    <span class="badge"><%= p.team_short_name || p.team_name || "—" %></span>
                  </td>
                  <td class="px-3 py-3 text-center">
                    <% grade = p.overall_grade %>
                    <% if grade %>
                      <span class="text-sm font-bold rounded px-1.5 py-0.5 text-white" style="background: <%= grade_color(grade) %>;">
                        <%= grade.round(1) %>
                      </span>
                      <% if overall_range %>
                        <span class="block text-xs text-muted mt-0.5"><%= overall_range[0] %>–<%= overall_range[1] %></span>
                      <% end %>
                    <% end %>
                  </td>
                  <td class="hidden md:table-cell px-3 py-3 text-center">
                    <% if primary_val %>
                      <span class="text-xs font-semibold" style="color: <%= grade_color(primary_val) %>;"><%= primary_val.round(1) %></span>
                      <span class="block text-xs text-muted"><%= primary_label %></span>
                      <% if primary_range %>
                        <span class="block text-xs text-muted"><%= primary_range[0] %>–<%= primary_range[1] %></span>
                      <% end %>
                    <% else %>
                      <span class="text-xs text-muted">—</span>
                    <% end %>
                  </td>
                  <td class="hidden lg:table-cell px-3 py-3 text-center">
                    <% if secondary_val %>
                      <span class="text-xs font-semibold" style="color: <%= grade_color(secondary_val) %>;"><%= secondary_val.round(1) %></span>
                      <span class="block text-xs text-muted"><%= secondary_label %></span>
                      <% if secondary_range %>
                        <span class="block text-xs text-muted"><%= secondary_range[0] %>–<%= secondary_range[1] %></span>
                      <% end %>
                    <% else %>
                      <span class="text-xs text-muted">—</span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="text-center py-12">
          <p class="text-muted">No prospect data available.</p>
        </div>
      <% end %>
    </div>
  </div>
</section>
