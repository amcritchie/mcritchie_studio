<% content_for :title, "NFL Coaches — 2025 Season" %>
<% content_for :full_width, true %>

<section class="py-6 px-4">
  <div class="max-w-5xl mx-auto">
    <%= link_to nfl_hub_path, class: "inline-flex items-center gap-1 text-sm text-secondary hover:text-heading transition mb-4" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      NFL Hub
    <% end %>

    <%# Hero %>
    <div class="rounded-xl overflow-hidden mb-8" style="background: linear-gradient(135deg, var(--color-cta), var(--color-cta-hover));">
      <div class="py-8 px-6 text-center">
        <span class="text-4xl block mb-2">🎙️</span>
        <h1 class="text-2xl md:text-3xl font-extrabold text-white">NFL Coaches</h1>
        <p class="text-white/70 text-sm mt-1">2025 NFL Season</p>
      </div>
    </div>

    <%# Search + sort controls %>
    <div class="card p-4 mb-6">
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div class="flex-1 max-w-sm">
          <form method="get" action="<%= nfl_coaches_path %>">
            <input type="hidden" name="sort" value="<%= @sort_by %>">
            <div class="relative">
              <input type="text" name="search" value="<%= params[:search] %>"
                     placeholder="Search coaches, teams..."
                     class="input-field w-full pl-10 pr-4 py-2 text-sm">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <svg class="h-4 w-4 text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
              </div>
            </div>
          </form>
        </div>

        <div class="flex gap-2">
          <% { "team" => "By Team", "role" => "By Role", "name" => "By Name" }.each do |key, label| %>
            <%= link_to label,
                  nfl_coaches_path(sort: key, search: params[:search]),
                  class: "px-4 py-2 rounded-lg text-sm font-semibold transition #{@sort_by == key ? 'btn btn-primary' : 'bg-surface-alt text-secondary hover:text-heading'}" %>
          <% end %>
        </div>
      </div>
    </div>

    <%# Coaches table %>
    <div class="card overflow-hidden">
      <div class="px-5 py-3 border-b border-subtle flex items-center gap-2">
        <span class="text-lg">🎙️</span>
        <h2 class="font-bold text-heading text-sm">NFL Coaches</h2>
        <span class="text-xs text-muted ml-auto"><%= @coaches.size %> coaches</span>
      </div>

      <% if @coaches.any? %>
        <div class="overflow-x-auto">
          <table class="min-w-full">
            <thead>
              <tr class="bg-surface-alt text-xs text-muted uppercase tracking-wider">
                <th class="px-3 py-2 text-center w-12">#</th>
                <th class="px-3 py-2 text-center w-12"></th>
                <th class="px-3 py-2 text-left">Coach</th>
                <th class="px-3 py-2 text-left">Team</th>
                <th class="px-3 py-2 text-center">Role</th>
                <th class="hidden md:table-cell px-3 py-2 text-center">Lean</th>
                <th class="hidden md:table-cell px-3 py-2 text-center">Conf</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-subtle">
              <% @coaches.each_with_index do |c, i| %>
                <tr class="hover:bg-surface-alt transition-colors">
                  <td class="px-3 py-3 text-center">
                    <span class="text-xs font-bold text-muted"><%= i + 1 %></span>
                  </td>
                  <td class="px-3 py-3 text-center text-lg">
                    <%= c.team_emoji || '🏈' %>
                  </td>
                  <td class="px-3 py-3">
                    <p class="font-bold text-heading text-sm"><%= c.first_name %> <%= c.last_name %></p>
                  </td>
                  <td class="px-3 py-3">
                    <span class="badge"><%= c.team_short_name || c.team_name || "—" %></span>
                  </td>
                  <td class="px-3 py-3 text-center">
                    <% role_label = c.role.titleize.gsub("Special Teams", "ST") %>
                    <% role_color = case c.role
                       when "head_coach" then "bg-primary/20 text-primary"
                       when "offensive_coordinator" then "bg-green-500/20 text-green-400"
                       when "defensive_coordinator" then "bg-red-500/20 text-red-400"
                       when "special_teams_coordinator" then "bg-yellow-500/20 text-yellow-400"
                       end %>
                    <span class="text-xs font-semibold px-2 py-0.5 rounded-full <%= role_color %>"><%= role_label %></span>
                  </td>
                  <td class="hidden md:table-cell px-3 py-3 text-center">
                    <% if c.lean.present? %>
                      <span class="text-xs font-semibold <%= c.lean == 'offense' ? 'text-green-400' : 'text-red-400' %>"><%= c.lean.capitalize %></span>
                    <% else %>
                      <span class="text-xs text-muted">—</span>
                    <% end %>
                  </td>
                  <td class="hidden md:table-cell px-3 py-3 text-center text-xs text-muted">
                    <%= c.conference %> <%= c.division %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="text-center py-12">
          <p class="text-muted">No coaches data available.</p>
        </div>
      <% end %>
    </div>
  </div>
</section>
