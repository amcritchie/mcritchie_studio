<section>
  <div class="mb-6">
    <%= link_to "&larr; All Agents".html_safe, agents_path, class: "text-secondary hover:text-heading text-sm transition" %>
  </div>

  <!-- Agent Header -->
  <div class="card p-6 mb-6">
    <div class="flex items-center gap-4 mb-4">
      <%= render "components/agent_avatar", agent: @agent, size: "lg" %>
      <div>
        <h2 class="text-2xl font-bold text-heading"><%= @agent.name %></h2>
        <p class="text-secondary"><%= @agent.title %></p>
        <div class="flex items-center gap-2 mt-1">
          <%= render "components/agent_status", agent: @agent %>
          <span class="text-xs text-muted">|</span>
          <span class="text-xs text-muted"><%= @agent.agent_type %></span>
        </div>
      </div>
    </div>
    <% if @agent.description.present? %>
      <p class="text-body text-sm"><%= @agent.description %></p>
    <% end %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Skills -->
    <div>
      <h3 class="text-lg font-bold text-heading mb-3">Skills</h3>
      <% if @skills.any? %>
        <div class="space-y-2">
          <% @skills.each do |skill| %>
            <div class="card p-3">
              <p class="text-heading text-sm font-medium"><%= skill.name %></p>
              <p class="text-muted text-xs"><%= skill.category %></p>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-muted text-sm">No skills assigned.</p>
      <% end %>
    </div>

    <!-- Tasks -->
    <div>
      <h3 class="text-lg font-bold text-heading mb-3">Recent Tasks</h3>
      <% if @tasks.any? %>
        <div class="space-y-2">
          <% @tasks.each do |task| %>
            <%= link_to task_path(task.slug), class: "block card p-3 hover:border-primary/30 transition" do %>
              <p class="text-heading text-sm font-medium truncate"><%= task.title %></p>
              <div class="flex items-center gap-2 mt-1">
                <%= render "components/badge", text: task.stage.humanize, scheme: stage_scheme(task.stage) %>
              </div>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <p class="text-muted text-sm">No tasks yet.</p>
      <% end %>
    </div>

    <!-- Activity -->
    <div>
      <h3 class="text-lg font-bold text-heading mb-3">Recent Activity</h3>
      <% if @activities.any? %>
        <div class="space-y-2">
          <% @activities.each do |activity| %>
            <div class="card p-3">
              <div class="flex items-center gap-2">
                <%= render "components/badge", text: activity.activity_type, scheme: "violet" %>
                <span class="text-xs text-muted"><%= time_ago_in_words(activity.created_at) %> ago</span>
              </div>
              <p class="text-body text-sm mt-1"><%= activity.description %></p>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-muted text-sm">No activity yet.</p>
      <% end %>
    </div>
  </div>
</section>
