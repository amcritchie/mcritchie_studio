<section>
  <h2 class="text-2xl font-bold text-heading mb-6">Agents</h2>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <% @agents.each do |agent| %>
      <%= link_to agent_path(agent.slug), class: "block card p-6 hover:border-primary/30 hover:shadow-lg hover:shadow-primary/5 transition" do %>
        <div class="flex items-center gap-4 mb-4">
          <%= render "components/agent_avatar", agent: agent, size: "md" %>
          <div>
            <h3 class="text-heading font-bold text-lg"><%= agent.name %></h3>
            <p class="text-secondary text-sm"><%= agent.title %></p>
          </div>
          <div class="ml-auto flex items-center gap-2">
            <%= render "components/agent_status", agent: agent %>
          </div>
        </div>
        <% if agent.description.present? %>
          <p class="text-secondary text-sm mb-4"><%= agent.description %></p>
        <% end %>
        <div class="flex items-center gap-4 text-xs text-muted">
          <span><%= agent.agent_type %></span>
          <span><%= agent.tasks.size %> tasks</span>
          <% if agent.last_active_at %>
            <span>Active <%= time_ago_in_words(agent.last_active_at) %> ago</span>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>
</section>
