<% content_for :title, "#{@team.short_name} — Pass & Run Grades" %>

<section class="py-6">
  <%# Back link %>
  <div class="mb-4">
    <%= link_to nfl_hub_path, class: "text-sm text-secondary hover:text-primary transition" do %>
      &larr; NFL Hub
    <% end %>
  </div>

  <%# Hero %>
  <% primary = @team.color_primary || "#6366f1" %>
  <% secondary = @team.color_secondary || "#1f2937" %>
  <div class="rounded-xl overflow-hidden mb-8" style="background: linear-gradient(135deg, <%= primary %> 0%, <%= secondary %> 100%);">
    <div class="relative py-8 px-6" style="background: rgba(0,0,0,0.3);">
      <div class="text-center">
        <span class="text-5xl block mb-2"><%= @team.emoji %></span>
        <p class="text-white/80 text-xs uppercase tracking-wider"><%= @team.location %></p>
        <p class="text-white font-extrabold text-2xl"><%= @team.name.sub(@team.location.to_s, "").strip %></p>
        <p class="text-white/60 text-xs font-mono mt-1"><%= @team.short_name %></p>
        <p class="text-white/80 text-sm mt-3 font-bold tracking-wide">PROPRIETARY PASS &amp; RUN GRADES</p>
      </div>
    </div>
  </div>

  <%# Legend %>
  <div class="card p-4 mb-6 flex items-center justify-center gap-6 flex-wrap text-xs">
    <span class="text-muted uppercase tracking-wider font-semibold">Letter scale:</span>
    <span class="flex items-center gap-2"><span class="inline-flex w-7 h-7 items-center justify-center rounded-md font-bold bg-green-600 text-white">A</span><span class="text-secondary">10–8</span></span>
    <span class="flex items-center gap-2"><span class="inline-flex w-7 h-7 items-center justify-center rounded-md font-bold bg-lime-500 text-white">B</span><span class="text-secondary">7–5</span></span>
    <span class="flex items-center gap-2"><span class="inline-flex w-7 h-7 items-center justify-center rounded-md font-bold bg-amber-500 text-white">C</span><span class="text-secondary">4–2</span></span>
    <span class="flex items-center gap-2"><span class="inline-flex w-7 h-7 items-center justify-center rounded-md font-bold bg-red-500 text-white">D</span><span class="text-secondary">1–0</span></span>
  </div>

  <% unless @roster %>
    <div class="card p-8 text-center text-secondary">
      No roster found for <%= @team.short_name %>. Run <code class="font-mono text-xs">bin/rails db:seed</code> and <code class="font-mono text-xs">bin/rails espn:scrape_depth_charts</code> first.
    </div>
  <% else %>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <%# Offense %>
    <div>
      <h2 class="text-heading font-bold text-lg mb-3 flex items-center gap-2">
        <span class="inline-block px-2 py-0.5 rounded text-xs font-bold bg-green-600 text-white">OFF</span>
        Offense — Starting 12
      </h2>
      <div class="card divide-y divide-subtle">
        <% @offense.each do |slot, pick| %>
          <%= render "starter_row", slot: slot, pick: pick, side: :offense %>
        <% end %>
      </div>
    </div>

    <%# Defense %>
    <div>
      <h2 class="text-heading font-bold text-lg mb-3 flex items-center gap-2">
        <span class="inline-block px-2 py-0.5 rounded text-xs font-bold bg-blue-600 text-white">DEF</span>
        Defense — Starting 12
      </h2>
      <div class="card divide-y divide-subtle">
        <% @defense.each do |slot, pick| %>
          <%= render "starter_row", slot: slot, pick: pick, side: :defense %>
        <% end %>
      </div>
    </div>
  </div>

  <% end %>
</section>
