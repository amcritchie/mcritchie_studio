<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "McRitchie Studio" %></title>
    <%= render "layouts/studio/head" %>
  </head>

  <body x-data class="bg-page text-body min-h-screen">
    <div class="max-w-7xl mx-auto px-4 py-6">
      <header class="mb-8 flex items-center justify-between">
        <div class="flex items-center gap-6">
          <%= link_to root_path, class: "inline-flex items-center gap-3 group" do %>
            <%= image_tag "logo-icon.svg", class: "w-8 h-8" %>
            <h1 class="text-2xl font-extrabold text-heading tracking-tight">McRitchie <span class="text-primary">Studio</span></h1>
          <% end %>
          <nav class="flex items-center gap-4">
            <%= link_to "Dashboard", root_path, class: "text-secondary hover:text-primary text-sm font-medium transition" %>
            <%= link_to "Agents", agents_path, class: "text-secondary hover:text-primary text-sm font-medium transition" %>
            <%= link_to "Tasks", tasks_path, class: "text-secondary hover:text-primary text-sm font-medium transition" %>
            <%= link_to "Activity", activities_path, class: "text-secondary hover:text-primary text-sm font-medium transition" %>
            <%= link_to "Docs", docs_path, class: "text-secondary hover:text-primary text-sm font-medium transition" %>
            <%= render "components/admin_dropdown" %>
            <% turf_url = Rails.env.production? ? "https://turf.mcritchie.studio" : "http://localhost:3001" %>
            <%= link_to turf_url + (logged_in? ? "/sso_login" : ""), class: "inline-flex items-center gap-2.5 px-3 py-1.5 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-bold rounded-lg shadow-sm hover:shadow-emerald-500/20 transition", target: "_blank" do %>
              <img src="/turf-monster-logo.png" alt="" class="w-5 h-5">
              Turf Monster
            <% end %>
          </nav>
        </div>

        <div class="flex items-center gap-4">
          <%= render "components/theme_toggle" %>
          <% if logged_in? %>
            <span class="text-heading font-semibold text-sm"><%= current_user.display_name %></span>
            <%= link_to "Log out", logout_path, class: "text-secondary hover:text-heading text-sm font-medium transition" %>
          <% else %>
            <%= link_to "Log in", login_path, class: "text-heading hover:text-primary text-sm font-semibold transition" %>
            <%= link_to "Sign up", signup_path, class: "btn btn-primary btn-sm" %>
          <% end %>
        </div>
      </header>

      <%= render "layouts/studio/flash" %>

      <%= yield %>
    </div>
  </body>
</html>
