<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "McRitchie Studio" %></title>
    <%= render "layouts/studio/head" %>
  </head>

  <body x-data class="bg-page text-body min-h-screen" :class="{ 'dev-mode': $store.devMode }">
    <%= render "layouts/studio/flash" %>
    <% unless Rails.env.production? %>
      <div style="background:#eab308; color:#000; font-size:12px; font-weight:700; padding:2px 12px; position:relative;">
        <%= Rails.env.capitalize %> Environment
        <span style="position:absolute; right:8px; top:50%; transform:translateY(-50%);">
          <button @click="$store.devMode = !$store.devMode; localStorage.setItem('devMode', $store.devMode)"
                  class="rounded cursor-pointer"
                  style="font-size:10px; font-weight:700; padding:1px 6px;"
                  :style="$store.devMode ? 'background:rgba(0,0,0,0.4); color:#fff;' : 'background:rgba(0,0,0,0.2); color:#000;'">DEV MODE</button>
        </span>
      </div>
    <% end %>
    <header x-data="{ scrolled: false }" @scroll.window="scrolled = window.scrollY > 20"
            class="sticky top-0 z-50 bg-page transition-shadow duration-300"
            :class="scrolled && 'shadow-lg border-b border-subtle'">
      <div class="max-w-7xl mx-auto px-4 transition-all duration-300"
           :class="scrolled ? 'py-2' : 'py-6'">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-6">
            <%= link_to root_path, class: "inline-flex items-center gap-3 group" do %>
              <%= image_tag "logo-icon.svg", class: "transition-all duration-300", "x-bind:class": "scrolled ? 'w-5 h-5' : 'w-8 h-8'" %>
              <h1 class="font-extrabold text-heading tracking-tight transition-all duration-300"
                  x-bind:class="scrolled ? 'text-base' : 'text-2xl'">McRitchie <span class="text-primary">Studio</span></h1>
            <% end %>
            <nav class="hidden md:flex items-center gap-4">
              <%= link_to "Meet the Agents 🦞", activities_path, class: "text-secondary hover:text-primary text-sm font-medium transition" %>
            </nav>
          </div>

          <% if logged_in? %>
            <%= render "components/user_nav", show_logout_link: true %>
          <% else %>
            <div class="flex items-center gap-3">
              <span class="hidden md:flex items-center gap-3">
                <%= render "components/admin_dropdown" %>
                <%= render "components/theme_toggle" %>
              </span>
              <%= link_to "Log in", login_path, class: "btn btn-primary whitespace-nowrap" %>
            </div>
          <% end %>
        </div>
      </div>
      <%# Mobile sub-navbar %>
      <div class="flex md:hidden items-center gap-3 px-4 py-1.5 overflow-x-auto border-t border-subtle bg-surface-alt">
        <%= link_to "Meet the Agents 🦞", activities_path, class: "text-secondary hover:text-primary text-xs font-medium transition whitespace-nowrap" %>
        <% unless logged_in? %>
          <span class="ml-auto flex items-center gap-3">
            <%= render "components/admin_dropdown" %>
            <%= render "components/theme_toggle" %>
          </span>
        <% end %>
      </div>
    </header>

    <% if content_for?(:full_width) %>
      <%= yield %>
    <% else %>
      <div class="max-w-7xl mx-auto px-4 py-6">
        <%= yield %>
      </div>
    <% end %>
  </body>
</html>
