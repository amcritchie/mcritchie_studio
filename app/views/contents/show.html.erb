<section>
  <div class="mb-6 flex items-center justify-between">
    <%= link_to "&larr; All Content".html_safe, contents_path, class: "text-secondary hover:text-heading text-sm transition" %>
    <div class="flex items-center gap-2">
      <% if @content.workflow == "starter_post_x" && @content.team_slug.present? %>
        <%= link_to "👀 Preview", team_lineup_graphic_path(@content.team_slug),
              class: "btn btn-outline btn-sm", target: "_blank" %>
        <% if %w[idea hook script].include?(@content.stage) %>
          <%= button_to "🎬 Generate Assets",
                generate_lineup_assets_content_path(@content.slug),
                class: "btn btn-secondary btn-sm",
                form: { class: "inline-block", "data-turbo": "false" },
                data: { confirm: "This takes ~10–15s while we capture and upload to S3. Continue?" } %>
        <% end %>
      <% end %>
      <%= link_to "Edit", edit_content_path(@content.slug), class: "btn btn-primary btn-sm" %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Main Content -->
    <div class="lg:col-span-2 space-y-6">
      <%# Post-to-X call-to-action: shows for starter_post_x once assets are ready %>
      <% if @content.workflow == "starter_post_x" && @content.stage == "assets" %>
        <%
          intent_url   = "https://twitter.com/intent/tweet?text=#{ERB::Util.url_encode(@content.captions.to_s)}"
          x_creds_set  = %w[X_API_KEY X_API_SECRET X_ACCESS_TOKEN X_ACCESS_TOKEN_SECRET].all? { |k| ENV[k].present? }
        %>
        <div class="card p-6 border border-primary/30">
          <p class="label-upper mb-2 text-primary">Post to X</p>

          <%# AUTOMATED POST %>
          <div class="mb-4 pb-4 border-b border-subtle">
            <p class="text-sm text-body mb-3">
              <span class="font-semibold">Automated:</span>
              uploads the video and posts via the X API.
              <% unless x_creds_set %>
                <span class="text-warning text-xs block mt-1">⚠ X_API_KEY / X_API_SECRET / X_ACCESS_TOKEN / X_ACCESS_TOKEN_SECRET not set in .env — automated post disabled.</span>
              <% end %>
            </p>
            <%= button_to "🚀 Post to X (auto)",
                  post_to_x_content_path(@content.slug),
                  class: "btn btn-primary",
                  disabled: !x_creds_set,
                  form: { class: "inline-block", "data-turbo": "false" },
                  data: { confirm: "Upload + post immediately. ~30–60s. Continue?" } %>
          </div>

          <%# MANUAL POST %>
          <p class="text-sm text-body mb-3">
            <span class="font-semibold">Manual fallback:</span>
            download → compose on X → paste the URL here.
          </p>
          <div class="flex flex-wrap items-center gap-2 mb-3">
            <% if @content.final_video_url.present? %>
              <%= link_to "⬇ Download Video", @content.final_video_url,
                    class: "btn btn-outline btn-sm", target: "_blank", download: "" %>
            <% end %>
            <%= link_to "📤 Open X Compose", intent_url,
                  class: "btn btn-outline btn-sm", target: "_blank", rel: "noopener" %>
          </div>
          <%= form_with url: post_step_content_path(@content.slug), method: :post, local: true,
                        html: { class: "flex flex-col sm:flex-row gap-2" } do %>
            <input type="url"
                   name="post_url"
                   required
                   placeholder="https://x.com/TurfMonster/status/1234567890"
                   class="input-field flex-1">
            <button type="submit" class="btn btn-secondary">Mark as Posted</button>
          <% end %>
        </div>
      <% end %>

      <div class="card p-6">
        <div class="flex items-start justify-between mb-4">
          <div>
            <h2 class="text-2xl font-bold text-heading"><%= @content.title %></h2>
            <div class="flex items-center gap-3 mt-2">
              <%= render "components/badge", text: @content.stage.humanize, scheme: content_stage_scheme(@content.stage) %>
              <% if @content.content_type.present? %>
                <span class="text-xs text-secondary"><%= @content.content_type.humanize %></span>
              <% end %>
            </div>
          </div>
          <span class="text-xs text-muted font-mono"><%= @content.slug %></span>
        </div>

        <% if @content.description.present? %>
          <div class="mb-4">
            <p class="label-upper">Description</p>
            <p class="text-body text-sm whitespace-pre-wrap"><%= @content.description %></p>
          </div>
        <% end %>

        <%# Reference Video %>
        <% if @content.reference_video_url.present? %>
          <div class="mb-4">
            <p class="label-upper">Reference Video</p>
            <a href="<%= @content.reference_video_url %>" target="_blank" class="text-primary text-sm hover:text-primary-300"><%= @content.reference_video_url.truncate(60) %></a>
            <% if @content.reference_video_start.present? %>
              <span class="text-muted text-xs ml-2">
                <%= @content.reference_video_start %>s - <%= @content.reference_video_end || "end" %>s
              </span>
            <% end %>
          </div>
        <% end %>

        <% if @content.hook_ideas.present? && @content.hook_ideas.any? %>
          <div class="mb-4">
            <p class="label-upper">Hook Ideas</p>
            <div class="space-y-2 mt-1">
              <% @content.hook_ideas.each_with_index do |hook, i| %>
                <div class="bg-surface-alt rounded-lg p-3 text-sm text-body flex items-start gap-2">
                  <% if @content.selected_hook_index == i %>
                    <span class="text-primary font-bold text-xs mt-0.5">SELECTED</span>
                  <% else %>
                    <span class="text-muted text-xs mt-0.5"><%= i + 1 %>.</span>
                  <% end %>
                  <span><%= hook %></span>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <% if @content.hook_image_url.present? %>
          <div class="mb-4 rounded-lg overflow-hidden">
            <p class="label-upper mb-1">Hook Image</p>
            <img src="<%= @content.hook_image_url %>" alt="Hook image" class="w-full h-48 object-cover rounded-lg">
          </div>
        <% end %>

        <% if @content.script_text.present? %>
          <div class="mb-4">
            <p class="label-upper">Script</p>
            <p class="text-body text-sm whitespace-pre-wrap"><%= @content.script_text %></p>
          </div>
        <% end %>

        <% if @content.scenes.present? && @content.scenes.any? %>
          <div class="mb-4">
            <p class="label-upper">Scenes</p>
            <div class="space-y-2 mt-1">
              <% @content.scenes.each do |scene| %>
                <div class="bg-surface-alt rounded-lg p-3">
                  <div class="flex items-center justify-between mb-1">
                    <span class="text-xs font-bold text-heading">Scene <%= scene["number"] || scene["scene_number"] %></span>
                    <% if scene["duration"] || scene["duration_seconds"] %>
                      <span class="text-[10px] text-muted"><%= scene["duration"] || scene["duration_seconds"] %>s</span>
                    <% end %>
                  </div>
                  <% if scene["description"] %>
                    <p class="text-sm text-body"><%= scene["description"] %></p>
                  <% end %>
                  <% if scene["camera"] %>
                    <p class="text-[10px] text-secondary mt-1"><%= scene["camera"] %></p>
                  <% end %>
                  <% if scene["screen_direction"] %>
                    <p class="text-[10px] text-secondary mt-1"><%= scene["screen_direction"] %></p>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <%# Scene Assets %>
        <% if @content.scene_assets.present? && @content.scene_assets.any? %>
          <div class="mb-4">
            <p class="label-upper">Scene Assets</p>
            <div class="grid grid-cols-2 gap-2 mt-1">
              <% @content.scene_assets.each do |asset| %>
                <div class="bg-surface-alt rounded-lg p-3">
                  <p class="text-xs font-bold text-heading mb-1">Scene <%= asset["scene_number"] %></p>
                  <% if asset["image_url"] %>
                    <img src="<%= asset["image_url"] %>" alt="Scene <%= asset["scene_number"] %>" class="w-full h-24 object-cover rounded">
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <% if @content.final_video_url.present? %>
          <div class="mb-4">
            <p class="label-upper">Final Video</p>
            <a href="<%= @content.final_video_url %>" target="_blank" class="text-primary text-sm hover:text-primary-300"><%= @content.final_video_url.truncate(60) %></a>
          </div>
        <% end %>

        <%# Captions & Hashtags %>
        <% if @content.captions.present? %>
          <div class="mb-4">
            <p class="label-upper">Caption</p>
            <p class="text-body text-sm whitespace-pre-wrap"><%= @content.captions %></p>
          </div>
        <% end %>

        <% if @content.hashtags.present? && @content.hashtags.any? %>
          <div class="mb-4">
            <p class="label-upper">Hashtags</p>
            <div class="flex flex-wrap gap-1 mt-1">
              <% @content.hashtags.each do |tag| %>
                <span class="bg-surface-alt text-secondary text-xs px-2 py-0.5 rounded">#<%= tag %></span>
              <% end %>
            </div>
          </div>
        <% end %>

        <% if @content.music_suggestions.present? && @content.music_suggestions.any? %>
          <div class="mb-4">
            <p class="label-upper">Music Suggestions</p>
            <ul class="list-disc list-inside space-y-1 mt-1">
              <% @content.music_suggestions.each do |track| %>
                <li class="text-body text-sm"><%= track %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <% if @content.post_url.present? %>
          <div class="mb-4">
            <p class="label-upper">Post</p>
            <a href="<%= @content.post_url %>" target="_blank" class="text-primary text-sm hover:text-primary-300"><%= @content.post_url.truncate(60) %></a>
          </div>
        <% end %>

        <% if @content.review_notes.present? %>
          <div class="mb-4">
            <p class="label-upper">Review Notes</p>
            <p class="text-body text-sm whitespace-pre-wrap"><%= @content.review_notes %></p>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Sidebar -->
    <div class="space-y-6">
      <!-- Details Card -->
      <div class="card p-6">
        <p class="label-upper mb-3">Details</p>
        <div class="space-y-3">
          <% if @content.source_type.present? %>
            <div>
              <p class="text-[10px] text-muted uppercase tracking-wider">Source</p>
              <p class="text-heading text-sm"><%= @content.source_type.humanize %></p>
            </div>
          <% end %>

          <% if @content.source_news.present? %>
            <div>
              <p class="text-[10px] text-muted uppercase tracking-wider">From News</p>
              <a href="<%= news_path(@content.source_news.slug) %>" class="text-primary text-sm hover:text-primary-300"><%= @content.source_news.title.truncate(40) %></a>
            </div>
          <% end %>

          <% if @content.rival_team.present? %>
            <div>
              <p class="text-[10px] text-muted uppercase tracking-wider">Rival Team</p>
              <p class="text-heading text-sm"><%= @content.rival_team.emoji %> <%= @content.rival_team.name %></p>
            </div>
          <% end %>

          <% if @content.duration_seconds.present? %>
            <div>
              <p class="text-[10px] text-muted uppercase tracking-wider">Duration</p>
              <p class="text-heading text-sm"><%= @content.duration_seconds %>s</p>
            </div>
          <% end %>

          <% if @content.platform.present? && (@content.stage == "posted" || @content.stage == "reviewed") %>
            <div>
              <p class="text-[10px] text-muted uppercase tracking-wider">Platform</p>
              <p class="text-heading text-sm"><%= @content.platform.humanize %></p>
            </div>
          <% end %>

          <% if @content.views.present? %>
            <div>
              <p class="text-[10px] text-muted uppercase tracking-wider">Performance</p>
              <div class="grid grid-cols-2 gap-2 mt-1">
                <div class="bg-surface-alt rounded p-2 text-center">
                  <p class="text-heading font-bold text-sm"><%= number_with_delimiter(@content.views) %></p>
                  <p class="text-[10px] text-muted">Views</p>
                </div>
                <div class="bg-surface-alt rounded p-2 text-center">
                  <p class="text-heading font-bold text-sm"><%= number_with_delimiter(@content.likes || 0) %></p>
                  <p class="text-[10px] text-muted">Likes</p>
                </div>
                <div class="bg-surface-alt rounded p-2 text-center">
                  <p class="text-heading font-bold text-sm"><%= number_with_delimiter(@content.comments_count || 0) %></p>
                  <p class="text-[10px] text-muted">Comments</p>
                </div>
                <div class="bg-surface-alt rounded p-2 text-center">
                  <p class="text-heading font-bold text-sm"><%= number_with_delimiter(@content.shares || 0) %></p>
                  <p class="text-[10px] text-muted">Shares</p>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Timeline Card -->
      <div class="card p-6">
        <p class="label-upper mb-3">Timeline</p>
        <div class="space-y-2">
          <div class="bg-surface-alt rounded-lg p-3">
            <p class="text-[10px] text-muted uppercase tracking-wider">Created</p>
            <p class="text-heading text-sm"><%= @content.created_at.strftime("%b %d, %H:%M") %></p>
          </div>
          <% if @content.hooked_at %>
            <div class="bg-surface-alt rounded-lg p-3">
              <p class="text-[10px] text-muted uppercase tracking-wider">Hooked</p>
              <p class="text-heading text-sm"><%= @content.hooked_at.strftime("%b %d, %H:%M") %></p>
            </div>
          <% end %>
          <% if @content.scripted_at %>
            <div class="bg-surface-alt rounded-lg p-3">
              <p class="text-[10px] text-muted uppercase tracking-wider">Scripted</p>
              <p class="text-heading text-sm"><%= @content.scripted_at.strftime("%b %d, %H:%M") %></p>
            </div>
          <% end %>
          <% if @content.asset_at %>
            <div class="bg-surface-alt rounded-lg p-3">
              <p class="text-[10px] text-muted uppercase tracking-wider">Assets</p>
              <p class="text-heading text-sm"><%= @content.asset_at.strftime("%b %d, %H:%M") %></p>
            </div>
          <% end %>
          <% if @content.assembled_at %>
            <div class="bg-surface-alt rounded-lg p-3">
              <p class="text-[10px] text-muted uppercase tracking-wider">Assembled</p>
              <p class="text-heading text-sm"><%= @content.assembled_at.strftime("%b %d, %H:%M") %></p>
            </div>
          <% end %>
          <% if @content.posted_at %>
            <div class="bg-surface-alt rounded-lg p-3">
              <p class="text-[10px] text-muted uppercase tracking-wider">Posted</p>
              <p class="text-heading text-sm"><%= @content.posted_at.strftime("%b %d, %H:%M") %></p>
            </div>
          <% end %>
          <% if @content.reviewed_at %>
            <div class="bg-surface-alt rounded-lg p-3">
              <p class="text-[10px] text-muted uppercase tracking-wider">Reviewed</p>
              <p class="text-heading text-sm"><%= @content.reviewed_at.strftime("%b %d, %H:%M") %></p>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Actions -->
      <% if logged_in? %>
        <div class="space-y-3">
          <%# Manual step buttons %>
          <div class="flex flex-wrap gap-2">
            <% if @content.stage == "idea" %>
              <%= button_to "Hook", hook_step_content_path(@content.slug), class: "btn btn-primary btn-sm" %>
            <% end %>
            <% if @content.stage == "hook" %>
              <%= button_to "Script", script_step_content_path(@content.slug), class: "btn btn-primary btn-sm" %>
            <% end %>
            <% if @content.stage == "script" %>
              <%= button_to "Assets", assets_step_content_path(@content.slug), class: "btn btn-primary btn-sm" %>
            <% end %>
            <% if @content.stage == "assets" %>
              <%= button_to "Assemble", assemble_step_content_path(@content.slug), class: "btn btn-primary btn-sm" %>
            <% end %>
            <% if @content.stage == "assembly" %>
              <%= button_to "Post", post_step_content_path(@content.slug), class: "btn btn-primary btn-sm" %>
            <% end %>
            <% if @content.stage == "posted" %>
              <%= button_to "Review", review_step_content_path(@content.slug), class: "btn btn-primary btn-sm" %>
            <% end %>
          </div>

          <%# AI Agent buttons %>
          <div class="flex flex-wrap gap-2">
            <% if @content.stage == "hook" %>
              <%= button_to "Generate Script", script_agent_step_content_path(@content.slug), class: "btn btn-secondary btn-sm" %>
            <% end %>
            <% if @content.stage == "script" %>
              <%= button_to "Generate Images", assets_agent_step_content_path(@content.slug), class: "btn btn-secondary btn-sm" %>
            <% end %>
            <% if @content.stage == "assets" %>
              <%= button_to "Assemble Video", assemble_agent_step_content_path(@content.slug), class: "btn btn-secondary btn-sm" %>
            <% end %>
            <% if @content.stage == "assembly" %>
              <%= button_to "Finalize", finalize_step_content_path(@content.slug), class: "btn btn-secondary btn-sm" %>
            <% end %>
            <%= button_to "Generate Metadata", metadata_step_content_path(@content.slug), class: "btn btn-outline btn-sm" %>
          </div>

          <%= button_to "Delete", content_path(@content.slug), method: :delete, class: "btn btn-danger btn-sm", data: { turbo_confirm: "Delete this content?" } %>
        </div>
      <% end %>
    </div>
  </div>
</section>
