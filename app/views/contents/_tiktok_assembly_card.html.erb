<%# Creator copilot card. Shows when workflow is starter_post_tiktok_*
    AND stage = "assembly" (i.e., after PrepForTiktok has run). Variants
    are picked here, music vibes shown, three handoff paths to actually
    posting (Begin Post manual, Auto-Upload Playwright, Mark Posted form). %>
<%
  variants     = Array(@content.caption_variants)
  hashtag_str  = Array(@content.hashtags).map { |h| "##{h}" }.join(" ")
  full_caption = [@content.captions, hashtag_str.presence].compact.join("\n\n")
  side_label   = @content.lineup_side.to_s.upcase
  mp4_url      = @content.final_video_url
%>
<div class="card p-6 border-2 border-primary/40 space-y-5">
  <div class="flex items-center justify-between">
    <p class="label-upper text-primary">🎬 Ready to Post · <%= side_label %></p>
    <span class="text-xs text-muted">creator copilot</span>
  </div>

  <% if mp4_url.present? %>
    <video src="<%= mp4_url %>" class="w-full max-w-sm mx-auto rounded-lg shadow-lg" autoplay loop muted playsinline></video>
  <% end %>

  <% if variants.any? %>
    <div>
      <p class="label-upper mb-2 text-secondary">Caption — pick a variant</p>
      <div class="space-y-2">
        <% variants.each_with_index do |v, i| %>
          <% selected = (v == @content.captions) %>
          <div class="flex items-start gap-3 p-3 rounded-lg border <%= selected ? 'border-primary bg-primary/5' : 'border-subtle bg-surface-alt' %>">
            <div class="flex-1">
              <div class="text-xs text-muted mb-1 font-mono">VARIANT <%= i + 1 %><%= " · selected" if selected %></div>
              <div class="text-body whitespace-pre-line"><%= v %></div>
            </div>
            <% unless selected %>
              <%= button_to "Use this",
                    use_caption_variant_content_path(@content.slug, index: i),
                    class: "btn btn-outline btn-sm flex-shrink-0",
                    form: { class: "inline-block", "data-turbo": "false" } %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if Array(@content.music_suggestions).any? %>
    <div>
      <p class="label-upper mb-2 text-secondary">🎵 Search TikTok for a sound matching:</p>
      <ul class="space-y-1 text-sm text-body list-disc pl-5">
        <% Array(@content.music_suggestions).each do |vibe| %>
          <li><%= vibe %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if Array(@content.hashtags).any? %>
    <div>
      <p class="label-upper mb-2 text-secondary">Hashtags (auto-included in copy)</p>
      <div class="text-sm text-body font-mono"><%= hashtag_str %></div>
    </div>
  <% end %>

  <%# BEGIN POST HANDOFF — clipboard + download + open Studio %>
  <div class="pt-4 border-t border-subtle space-y-3"
       data-controller-stub="begin-post"
       data-caption="<%= ERB::Util.html_escape(full_caption) %>"
       data-mp4="<%= mp4_url %>"
       data-studio-url="https://www.tiktok.com/tiktokstudio/upload">
    <button type="button"
            onclick="window.beginTiktokPost(this)"
            class="btn btn-primary btn-lg w-full"
            <%= "disabled" if mp4_url.blank? %>>
      🚀 Begin Post — copy caption + download MP4 + open TikTok Studio
    </button>
    <p class="text-xs text-muted text-center">
      One click does three things: copies caption to clipboard, downloads the MP4, opens TikTok Studio in a new tab.
    </p>

    <%# Auto-upload via Playwright — local dev only (needs Chromium with display) %>
    <% if Rails.env.development? %>
      <%= button_to "🤖 Auto-Upload to TikTok Studio (you click Post)",
            studio_upload_to_tiktok_content_path(@content.slug),
            class: "btn btn-secondary btn-lg w-full",
            disabled: mp4_url.blank?,
            form: { class: "w-full", "data-turbo": "false" },
            data: { confirm: "Launches Chromium, uploads video + types caption, leaves browser open. ~30-60s. Continue?" } %>
      <p class="text-xs text-muted text-center">
        Agent does the upload + caption typing. You review and click Post in the browser. Requires <code>npm run tiktok:login</code> first.
      </p>
    <% end %>
  </div>

  <%# AFTER POSTING — paste URL OR use the no-URL escape hatch %>
  <div class="pt-4 border-t border-subtle space-y-3">
    <p class="label-upper text-secondary">After you publish on TikTok</p>
    <%= form_with url: mark_posted_content_path(@content.slug), method: :post, local: true,
                  html: { class: "flex flex-col sm:flex-row gap-2" } do %>
      <input type="hidden" name="platform" value="tiktok">
      <input type="url"
             name="post_url"
             placeholder="https://www.tiktok.com/@turfmonstershow/video/... (optional)"
             class="input-field flex-1">
      <button type="submit" class="btn btn-secondary">Mark Posted</button>
    <% end %>
    <p class="text-xs text-muted">URL is optional — leave blank if you'll paste it later via Edit.</p>
  </div>
</div>

<script>
  // Single-click handoff: clipboard + download + open Studio. Three side
  // effects from one tap so the user can drag the MP4 into TikTok Studio
  // and paste the caption with no fumbling.
  window.beginTiktokPost = async function(btn) {
    const root      = btn.closest('[data-controller-stub="begin-post"]');
    const caption   = root.dataset.caption;
    const mp4       = root.dataset.mp4;
    const studioUrl = root.dataset.studioUrl;

    // 1. Clipboard. Decode the HTML entities first.
    const decoded = new DOMParser().parseFromString(caption, 'text/html').body.textContent || '';
    try { await navigator.clipboard.writeText(decoded); } catch (e) { console.warn('clipboard write failed', e); }

    // 2. Download MP4 by injecting a hidden anchor with a download attribute.
    //    S3's content-disposition won't trigger download cross-origin without this.
    if (mp4) {
      const a = document.createElement('a');
      a.href = mp4;
      a.download = mp4.split('/').pop().split('?')[0] || 'lineup.mp4';
      a.target = '_blank';
      a.rel = 'noopener';
      document.body.appendChild(a);
      a.click();
      setTimeout(() => a.remove(), 200);
    }

    // 3. Open TikTok Studio in a new tab.
    window.open(studioUrl, '_blank', 'noopener');

    // 4. Toast (uses the global toast event from the studio engine).
    document.dispatchEvent(new CustomEvent('toast', { detail: {
      type: 'success',
      title: 'Caption copied · MP4 downloading · Studio opened',
      message: 'Drag the MP4 into TikTok Studio, paste caption, search the suggested sound vibe, hit publish.',
      duration: 7000
    }}));
  };
</script>
