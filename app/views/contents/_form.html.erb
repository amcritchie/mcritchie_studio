<div class="card p-6" x-data="{ workflow: '<%= content.workflow.presence || "video" %>' }">
  <% if content.errors.any? %>
    <div class="mb-4 p-3 bg-red-900/50 border border-red-700 rounded-lg text-red-300 text-sm">
      <% content.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <%= form_with model: content, url: content.persisted? ? content_path(content.slug) : contents_path do |f| %>
    <!-- Workflow -->
    <div class="mb-5">
      <label class="block text-sm text-secondary mb-2 font-medium">Workflow</label>
      <%= f.select :workflow,
            [["Video", "video"], ["Starter Post (X)", "starter_post_x"]],
            {},
            class: "input-field", "x-model": "workflow" %>
    </div>

    <!-- Idea -->
    <p class="label-upper mb-3">Idea</p>

    <div class="mb-5">
      <label class="block text-sm text-secondary mb-2 font-medium">Title</label>
      <%= f.text_field :title, class: "input-field", placeholder: "Content idea title" %>
    </div>

    <div class="mb-5">
      <label class="block text-sm text-secondary mb-2 font-medium">Description</label>
      <%= f.text_area :description, rows: 3, class: "input-field", placeholder: "What's the content about?" %>
    </div>

    <div class="grid grid-cols-2 gap-4 mb-5">
      <div>
        <label class="block text-sm text-secondary mb-2 font-medium">Source Type</label>
        <%= f.select :source_type, [["Studio", "studio"], ["Manual", "manual"], ["News", "news"]], { include_blank: true }, class: "input-field" %>
      </div>
      <div x-show="workflow === 'video'">
        <label class="block text-sm text-secondary mb-2 font-medium">Content Type</label>
        <%= f.select :content_type, [["TikTok Video", "tiktok_video"], ["Reel", "reel"], ["Short", "short"]], {}, class: "input-field" %>
      </div>
    </div>

    <!-- Reference & Context -->
    <div x-show="workflow === 'video'">
      <hr class="border-subtle my-6">
      <p class="label-upper mb-3">Reference & Context</p>

    <div class="mb-5">
      <label class="block text-sm text-secondary mb-2 font-medium">Reference Video URL</label>
      <%= f.url_field :reference_video_url, class: "input-field", placeholder: "https://youtube.com/watch?v=..." %>
    </div>

    <div class="grid grid-cols-2 gap-4 mb-5">
      <div>
        <label class="block text-sm text-secondary mb-2 font-medium">Start Time (seconds)</label>
        <%= f.number_field :reference_video_start, class: "input-field", min: 0, placeholder: "0" %>
      </div>
      <div>
        <label class="block text-sm text-secondary mb-2 font-medium">End Time (seconds)</label>
        <%= f.number_field :reference_video_end, class: "input-field", min: 0, placeholder: "30" %>
      </div>
    </div>

    <div class="mb-5">
      <label class="block text-sm text-secondary mb-2 font-medium">Rival Team</label>
      <%= f.select :rival_team_slug,
            Team.where(sport: "football", league: "nfl").order(:name).map { |t| ["#{t.emoji} #{t.name}", t.slug] },
            { include_blank: "— Select rival —" },
            class: "input-field" %>
    </div>
    </div>

    <!-- Starter Post X — Hook -->
    <div x-show="workflow === 'starter_post_x'" x-cloak>
      <hr class="border-subtle my-6">
      <p class="label-upper mb-3">Starter Post (X) — Hook</p>

      <div class="mb-5">
        <label class="block text-sm text-secondary mb-2 font-medium">Team (whose lineup)</label>
        <%= f.select :team_slug,
              Team.where(sport: "football", league: "nfl").order(:name).map { |t| ["#{t.emoji} #{t.name}", t.slug] },
              { include_blank: "— Select team —" },
              class: "input-field" %>
      </div>

      <div class="mb-5">
        <label class="block text-sm text-secondary mb-2 font-medium">Post Body (X tweet)</label>
        <%= f.text_area :captions, rows: 3, class: "input-field",
              placeholder: "Find the mistake in my Bills lineup 👀", maxlength: 280 %>
        <p class="text-xs text-muted mt-1">Max 280 characters.</p>
      </div>
    </div>

    <% if content.persisted? %>
      <div class="mb-5">
        <label class="block text-sm text-secondary mb-2 font-medium">Stage</label>
        <%= f.select :stage, Content::STAGES.map { |s| [s.humanize, s] }, {}, class: "input-field" %>
      </div>

      <hr class="border-subtle my-6">

      <!-- Hook -->
      <p class="label-upper mb-3">Hook</p>

      <div class="mb-5">
        <label class="block text-sm text-secondary mb-2 font-medium">Hook Image URL</label>
        <%= f.url_field :hook_image_url, class: "input-field", placeholder: "https://..." %>
      </div>

      <div class="mb-5">
        <label class="block text-sm text-secondary mb-2 font-medium">Selected Hook Index (0-2)</label>
        <%= f.number_field :selected_hook_index, class: "input-field", min: 0, max: 2 %>
      </div>

      <hr class="border-subtle my-6">

      <!-- Script -->
      <p class="label-upper mb-3">Script</p>

      <div class="mb-5">
        <label class="block text-sm text-secondary mb-2 font-medium">Script Text</label>
        <%= f.text_area :script_text, rows: 5, class: "input-field", placeholder: "Full script narrative..." %>
      </div>

      <div class="mb-5">
        <label class="block text-sm text-secondary mb-2 font-medium">Duration (seconds)</label>
        <%= f.number_field :duration_seconds, class: "input-field", min: 5, max: 60 %>
      </div>

      <hr class="border-subtle my-6">

      <!-- Assembly -->
      <p class="label-upper mb-3">Assembly</p>

      <div class="grid grid-cols-2 gap-4 mb-5">
        <div>
          <label class="block text-sm text-secondary mb-2 font-medium">Final Video URL</label>
          <%= f.url_field :final_video_url, class: "input-field", placeholder: "https://..." %>
        </div>
        <div>
          <label class="block text-sm text-secondary mb-2 font-medium">Music Track</label>
          <%= f.text_field :music_track, class: "input-field", placeholder: "Track name or URL" %>
        </div>
      </div>

      <div class="mb-5">
        <label class="inline-flex items-center gap-2">
          <%= f.check_box :logo_overlay, class: "rounded" %>
          <span class="text-sm text-secondary font-medium">Logo Overlay</span>
        </label>
      </div>

      <hr class="border-subtle my-6">

      <!-- Posted -->
      <p class="label-upper mb-3">Posted</p>

      <div class="grid grid-cols-2 gap-4 mb-5">
        <div>
          <label class="block text-sm text-secondary mb-2 font-medium">Platform</label>
          <%= f.select :platform, [["TikTok", "tiktok"], ["Instagram", "instagram"], ["YouTube", "youtube"]], {}, class: "input-field" %>
        </div>
        <div>
          <label class="block text-sm text-secondary mb-2 font-medium">Post URL</label>
          <%= f.url_field :post_url, class: "input-field", placeholder: "https://..." %>
        </div>
      </div>

      <div class="mb-5">
        <label class="block text-sm text-secondary mb-2 font-medium">Post ID</label>
        <%= f.text_field :post_id, class: "input-field", placeholder: "Platform post ID" %>
      </div>

      <hr class="border-subtle my-6">

      <!-- Reviewed -->
      <p class="label-upper mb-3">Reviewed</p>

      <div class="grid grid-cols-2 gap-4 mb-5">
        <div>
          <label class="block text-sm text-secondary mb-2 font-medium">Views</label>
          <%= f.number_field :views, class: "input-field" %>
        </div>
        <div>
          <label class="block text-sm text-secondary mb-2 font-medium">Likes</label>
          <%= f.number_field :likes, class: "input-field" %>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-4 mb-5">
        <div>
          <label class="block text-sm text-secondary mb-2 font-medium">Comments</label>
          <%= f.number_field :comments_count, class: "input-field" %>
        </div>
        <div>
          <label class="block text-sm text-secondary mb-2 font-medium">Shares</label>
          <%= f.number_field :shares, class: "input-field" %>
        </div>
      </div>

      <div class="mb-5">
        <label class="block text-sm text-secondary mb-2 font-medium">Review Notes</label>
        <%= f.text_area :review_notes, rows: 3, class: "input-field", placeholder: "Performance analysis..." %>
      </div>

    <% end %>

    <button type="submit" class="btn btn-primary btn-lg">
      <%= content.persisted? ? "Update Content" : "Create Idea" %>
    </button>
  <% end %>
</div>
