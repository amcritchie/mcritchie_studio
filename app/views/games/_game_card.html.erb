<%# Game card for week index page
    Locals: game, year, week %>

<%= link_to game_show_path(year, week, game.slug), class: "block rounded-lg overflow-hidden transition hover:shadow-lg hover:shadow-primary/10 group" do %>
  <div class="relative p-4" style="<%= game.hero_gradient_style %>">
    <%# Overlay for readability %>
    <div class="absolute inset-0" style="background: rgba(0,0,0,0.35);"></div>

    <div class="relative flex items-center justify-between gap-3">
      <%# Away team %>
      <div class="flex items-center gap-2 flex-1 min-w-0">
        <span class="text-2xl"><%= game.away_team.emoji %></span>
        <div class="min-w-0">
          <p class="text-white font-bold text-sm truncate"><%= game.away_team.location %></p>
          <p class="text-white/80 text-xs font-mono"><%= game.away_team.short_name %></p>
        </div>
      </div>

      <%# @ badge %>
      <div class="flex-shrink-0 px-3">
        <span class="text-white/60 text-xs font-bold">@</span>
      </div>

      <%# Home team %>
      <div class="flex items-center gap-2 flex-1 min-w-0 justify-end text-right">
        <div class="min-w-0">
          <p class="text-white font-bold text-sm truncate"><%= game.home_team.location %></p>
          <p class="text-white/80 text-xs font-mono"><%= game.home_team.short_name %></p>
        </div>
        <span class="text-2xl"><%= game.home_team.emoji %></span>
      </div>
    </div>
  </div>
<% end %>
