<% content_for :title, "NFL #{@year} Season" %>

<section class="py-6">
  <%# Hero %>
  <div class="text-center mb-8">
    <div class="flex items-center justify-center gap-3 mb-2">
      <h1 class="text-3xl md:text-4xl font-extrabold text-heading tracking-tight">
        NFL <%= @year %> Season
      </h1>
      <% if @season_options.size > 1 %>
        <select onchange="window.location.href='/games/' + this.value"
                class="bg-surface text-heading text-sm border border-subtle rounded px-2 py-1">
          <% @season_options.each do |y| %>
            <option value="<%= y %>" <%= "selected" if y == @year %>><%= y %></option>
          <% end %>
        </select>
      <% end %>
    </div>
    <p class="text-sm text-muted">
      <%= @regular_slates.size %> regular-season weeks · <%= @regular_slates.sum { |s| s.games.size } %> games
      <% if @other_slates.any? %>
        · <%= @other_slates.size %> additional slates
      <% end %>
    </p>
  </div>

  <%# Regular season grid — each card shows all games grouped by kickoff time slot %>
  <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4 mb-10">
    <% @regular_slates.each do |slate| %>
      <% games = slate.games.sort_by { |g| g.kickoff_at || Time.current + 100.years } %>
      <% range_start = games.first&.kickoff_at %>
      <% range_end = games.last&.kickoff_at %>

      <% is_current = slate.sequence == @current_week %>
      <% byes = @bye_teams_by_week[slate.sequence] || [] %>

      <%# Group games by their kickoff time slot (e.g. "Thu 8:20 PM ET", "Sun 1:00 PM ET") %>
      <% slots = games.group_by { |g| g.kickoff_at ? g.kickoff_at.in_time_zone("America/New_York").strftime("%a %-l:%M %p ET") : "TBD" } %>

      <%= link_to games_week_path(@year, slate.sequence),
            class: "block bg-surface border #{is_current ? "border-primary ring-1 ring-primary/40" : "border-subtle"} rounded-lg p-4 hover:border-primary transition group relative" do %>
        <% if is_current %>
          <span class="absolute -top-2 right-3 text-[10px] font-bold uppercase tracking-wider bg-primary text-white px-2 py-0.5 rounded">Upcoming</span>
        <% end %>

        <div class="flex items-baseline justify-between mb-1">
          <h2 class="text-xl font-bold text-heading group-hover:text-primary transition">
            Week <%= slate.sequence %>
          </h2>
          <span class="text-xs text-muted font-mono"><%= games.size %> games</span>
        </div>
        <% if range_start && range_end %>
          <p class="text-xs text-secondary mb-3">
            <%= range_start.in_time_zone("America/New_York").strftime("%b %-d") %><% if range_start.to_date != range_end.to_date %> – <%= range_end.in_time_zone("America/New_York").strftime("%b %-d") %><% end %>
          </p>
        <% end %>

        <%# All games by time slot — each row tinted with the two-team gradient %>
        <div class="space-y-2.5">
          <% slots.each do |slot_label, slot_games| %>
            <div>
              <div class="text-[10px] font-bold text-muted uppercase tracking-wider mb-1"><%= slot_label %></div>
              <%# 3 games per row at lg, 2 at sm, 1 on mobile. Every cell is exactly one column. %>
              <%# Neutral-site games append an emoji-only cell (same 1/3 width) as a sibling. %>
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-1">
                <% slot_games.each do |g| %>
                  <div class="relative rounded overflow-hidden" style="<%= g.row_gradient_style %>">
                    <div class="absolute inset-0 bg-black/55"></div>
                    <div class="relative flex items-center text-xs text-white px-2 py-1">
                      <span class="leading-none"><%= g.home_team.emoji %></span>
                      <span class="font-mono font-semibold ml-2"><%= g.home_team.short_name %></span>
                      <span class="text-white/50 mx-auto px-2">vs</span>
                      <span class="font-mono font-semibold mr-2"><%= g.away_team.short_name %></span>
                      <span class="leading-none"><%= g.away_team.emoji %></span>
                    </div>
                  </div>

                  <% if g.neutral_site? %>
                    <div class="rounded bg-surface-alt border border-subtle inline-flex items-center gap-1.5 text-[11px] text-secondary h-6 px-2 self-center min-w-0" title="<%= g.venue %>">
                      <span class="leading-none">🌍</span>
                      <span class="font-mono truncate"><%= g.venue %></span>
                    </div>
                  <% end %>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>

        <% if byes.any? %>
          <div class="mt-3 pt-2 border-t border-subtle/50 text-[11px] text-muted">
            <span class="font-mono"><%= byes.size %> on bye:</span>
            <span class="font-mono"><%= byes.join(", ") %></span>
          </div>
        <% end %>
      <% end %>
    <% end %>
  </div>

  <%# Other slates (preseason / playoffs) — render only if present %>
  <% if @other_slates.any? %>
    <div class="mt-12">
      <h2 class="text-lg font-bold text-heading mb-3 border-b border-subtle pb-2">Other slates</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
        <% @other_slates.each do |slate| %>
          <%= link_to games_week_path(@year, slate.sequence),
                class: "block bg-surface border border-subtle rounded-lg p-4 hover:border-primary transition group" do %>
            <div class="flex items-baseline justify-between mb-2">
              <h3 class="text-base font-bold text-heading group-hover:text-primary transition">
                <%= slate.label %>
              </h3>
              <span class="text-xs text-muted font-mono"><%= slate.games.size %> games</span>
            </div>
            <p class="text-xs text-secondary"><%= slate.slate_type.titleize %></p>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
</section>
