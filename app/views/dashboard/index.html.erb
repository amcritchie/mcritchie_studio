<section>
  <!-- Agent Cards -->
  <div class="mb-8">
    <h2 class="text-xl font-bold text-heading mb-4">Agents</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      <% @agents.each do |agent| %>
        <%= link_to agent_path(agent.slug), class: "block card p-5 hover:border-primary/30 hover:shadow-lg hover:shadow-primary/5 transition" do %>
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-full bg-primary/20 flex items-center justify-center">
              <span class="text-primary font-bold"><%= agent.name.first.upcase %></span>
            </div>
            <div>
              <h3 class="text-heading font-bold text-sm"><%= agent.name %></h3>
              <p class="text-muted text-xs"><%= agent.title %></p>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <span class="inline-block w-2 h-2 rounded-full <%= agent.status == 'active' ? 'bg-mint' : 'bg-gray-600' %>"></span>
            <span class="text-xs text-secondary"><%= agent.status.capitalize %></span>
          </div>
          <% if agent.description.present? %>
            <p class="text-muted text-xs mt-2 line-clamp-2"><%= agent.description %></p>
          <% end %>
        <% end %>
      <% end %>
    </div>
  </div>

  <!-- Task Pipeline -->
  <div class="mb-8">
    <h2 class="text-xl font-bold text-heading mb-4">Task Pipeline</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3">
      <% %w[new queued in_progress done failed archived].each do |stage| %>
        <%= link_to tasks_path(stage: stage), class: "block card p-4 text-center hover:border-primary/30 transition" do %>
          <p class="text-2xl font-bold text-heading"><%= @task_counts[stage] || 0 %></p>
          <p class="text-xs text-secondary mt-1"><%= stage.humanize %></p>
        <% end %>
      <% end %>
    </div>
  </div>

  <!-- Recent Activity -->
  <div>
    <h2 class="text-xl font-bold text-heading mb-4">Recent Activity</h2>
    <% if @recent_activities.empty? %>
      <%= render "components/empty_state", message: "No activity yet." %>
    <% else %>
      <div class="space-y-2">
        <% @recent_activities.each do |activity| %>
          <div class="card p-4 flex items-center justify-between">
            <div class="flex items-center gap-3">
              <%= render "components/badge", text: activity.activity_type, scheme: "violet" %>
              <span class="text-sm text-body"><%= activity.description %></span>
              <% if activity.agent_slug.present? %>
                <span class="text-xs text-muted">by <%= activity.agent_slug %></span>
              <% end %>
            </div>
            <span class="text-xs text-muted"><%= time_ago_in_words(activity.created_at) %> ago</span>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</section>
