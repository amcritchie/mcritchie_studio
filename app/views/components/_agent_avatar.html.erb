<%# locals: (agent:, size: "md") %>
<%#
  Renders the agent's avatar as a circle. Pattern: the deterministic
  initial-bubble is always rendered underneath; the <img> (when avatar is
  present) is positioned absolutely on top. If the file 404s, onerror
  removes the <img>, exposing the bubble — no broken-image icon, no flicker.
%>
<%
  sizes = {
    "sm" => { container: "w-10 h-10", text: "text-sm" },
    "md" => { container: "w-14 h-14", text: "text-xl" },
    "lg" => { container: "w-16 h-16", text: "text-2xl" },
  }
  s = sizes[size] || sizes["md"]
%>
<span class="<%= s[:container] %> rounded-full flex items-center justify-center relative overflow-hidden flex-shrink-0"
      style="background-color: <%= agent.avatar_color %>;">
  <span class="text-white font-bold <%= s[:text] %>"><%= agent.avatar_initials %></span>
  <% if agent.avatar.present? %>
    <img src="<%= agent.avatar %>"
         alt="<%= agent.name %>"
         class="absolute inset-0 w-full h-full rounded-full object-cover"
         loading="lazy"
         onerror="this.remove()">
  <% end %>
</span>
