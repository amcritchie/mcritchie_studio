<% content_for(:title, "Chat with Alex — McRitchie Studio") %>
<% content_for(:full_width, true) %>

<div class="flex flex-col" style="height: calc(100vh - 80px);" x-data="alexChat()">
  <!-- Header -->
  <div class="bg-surface border-b border-subtle px-4 py-3 flex items-center gap-3">
    <img src="/agents/alex.png" class="w-10 h-10 rounded-full" alt="Alex">
    <div>
      <h1 class="text-heading font-bold text-lg leading-tight">Alex McRitchie</h1>
      <p class="text-muted text-xs">Lead Orchestrator · McRitchie Studio</p>
    </div>
    <span class="w-2 h-2 rounded-full bg-green-500"></span>
  </div>

  <!-- Messages -->
  <div class="flex-1 overflow-y-auto px-4 py-6" x-ref="messages">
    <div class="max-w-3xl mx-auto space-y-4">
      <!-- Welcome state -->
      <template x-if="messages.length === 0 && !loading">
        <div class="text-center py-12">
          <img src="/agents/alex.png" class="w-16 h-16 rounded-full mx-auto mb-4 opacity-75" alt="Alex">
          <p class="text-secondary text-lg mb-2">Hey! I'm Alex.</p>
          <p class="text-muted">Ask me anything about McRitchie Studio, business acquisitions, or tech strategy.</p>
        </div>
      </template>

      <template x-for="msg in messages" :key="msg.id">
        <div :class="msg.role === 'user' ? 'flex justify-end' : 'flex justify-start'">
          <template x-if="msg.role === 'assistant'">
            <img src="/agents/alex.png" class="w-8 h-8 rounded-full mr-2 flex-shrink-0 mt-1" alt="Alex">
          </template>
          <div :class="msg.role === 'user'
            ? 'bg-primary text-white rounded-2xl rounded-br-sm px-4 py-2 max-w-lg'
            : 'card rounded-2xl rounded-bl-sm px-4 py-2 max-w-lg'"
            x-html="msg.role === 'assistant' ? formatMarkdown(msg.content) : null"
            x-text="msg.role === 'user' ? msg.content : null">
          </div>
        </div>
      </template>

      <!-- Loading indicator -->
      <template x-if="loading">
        <div class="flex justify-start">
          <img src="/agents/alex.png" class="w-8 h-8 rounded-full mr-2 flex-shrink-0 mt-1" alt="Alex">
          <div class="card rounded-2xl rounded-bl-sm px-4 py-3">
            <div class="flex gap-1">
              <span class="w-2 h-2 rounded-full bg-primary animate-bounce" style="animation-delay: 0ms"></span>
              <span class="w-2 h-2 rounded-full bg-primary animate-bounce" style="animation-delay: 150ms"></span>
              <span class="w-2 h-2 rounded-full bg-primary animate-bounce" style="animation-delay: 300ms"></span>
            </div>
          </div>
        </div>
      </template>
    </div>
  </div>

  <!-- Input -->
  <div class="border-t border-subtle bg-surface px-4 py-3">
    <form @submit.prevent="sendMessage" class="flex gap-2 max-w-3xl mx-auto">
      <input type="text" x-model="input" placeholder="Ask Alex anything..."
             class="input-field flex-1" :disabled="loading"
             x-ref="input">
      <button type="submit" class="btn btn-primary" :disabled="loading || !input.trim()">
        Send
      </button>
    </form>
  </div>
</div>
