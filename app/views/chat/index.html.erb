<% content_for(:title, "Chat with Alex — McRitchie Studio") %>
<% content_for(:full_width, true) %>

<div class="flex flex-col" style="height: calc(100vh - 80px);">
  <!-- Header -->
  <div class="bg-surface border-b border-subtle px-4 py-3 flex items-center gap-3">
    <img src="/agents/alex.png" class="w-10 h-10 rounded-full" alt="Alex">
    <div>
      <h1 class="text-heading font-bold text-lg leading-tight">Alex McRitchie</h1>
      <p class="text-muted text-xs">Lead Orchestrator · McRitchie Studio</p>
    </div>
    <span class="w-2 h-2 rounded-full bg-green-500"></span>
  </div>

  <%= render "chat/chat_widget" %>
</div>
