<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-extrabold text-heading"><%= @upload.filename %></h1>
    <p class="text-secondary text-sm mt-1 flex items-center gap-1.5">
      <% if @upload.payment_method&.logo.present? %>
        <img src="<%= @upload.payment_method.logo %>" alt="" class="w-4 h-4 object-contain">
      <% end %>
      <%= @upload.card_type_display %> &middot; Uploaded <%= @upload.created_at.strftime("%b %d, %Y") %>
    </p>
  </div>
  <div class="flex items-center gap-3">
    <% if @upload.pending? %>
      <%= button_to "Process File", process_file_expense_upload_path(@upload.slug), method: :post, class: "btn btn-primary btn-sm" %>
    <% elsif @upload.processed? %>
      <%= button_to "Run AI Evaluation", evaluate_expense_upload_path(@upload.slug), method: :post, class: "btn btn-primary btn-sm" %>
    <% end %>
    <%= button_to "Delete", expense_upload_path(@upload.slug), method: :delete, class: "btn btn-danger btn-sm",
        data: { turbo_confirm: "Delete this upload and all its transactions?" } %>
  </div>
</div>

<%# Evaluation Progress Bar %>
<% if @upload.evaluating? %>
<div x-data="evaluationProgress('<%= @upload.slug %>')" class="card p-5 mb-6">
  <div class="flex items-center gap-3 mb-3">
    <span class="label-upper">AI Evaluation</span>
    <span class="badge bg-primary/10 text-primary border-primary/30">
      <span class="inline-block w-2 h-2 rounded-full bg-primary animate-pulse mr-1.5"></span>
      Evaluating
    </span>
  </div>

  <%# Error state %>
  <template x-if="error">
    <div class="p-3 rounded-lg bg-red-500/10 border border-red-500/30 text-sm">
      <p class="font-bold text-red-400 mb-1">Evaluation Error</p>
      <p class="text-red-300" x-text="error"></p>
      <p class="text-muted text-xs mt-2">Refreshing in 3 seconds...</p>
    </div>
  </template>

  <%# Progress state %>
  <template x-if="!error">
    <div>
      <div class="flex items-center justify-between text-sm mb-2">
        <span class="text-secondary" x-text="statusText">Connecting...</span>
        <span class="text-heading font-mono font-bold" x-text="percentText">0%</span>
      </div>
      <div class="w-full h-3 rounded-full bg-surface-alt overflow-hidden">
        <div class="h-full rounded-full transition-all duration-500 ease-out"
             style="background-color: var(--color-cta)"
             :style="'width: ' + percent + '%'">
        </div>
      </div>
    </div>
  </template>
</div>
<% end %>

<%# Status + Summary %>
<div class="card p-5 mb-6">
  <div class="flex items-center gap-4 mb-4">
    <span class="label-upper">Status</span>
    <% case @upload.status %>
    <% when "pending" %>
      <span class="badge bg-yellow-500/10 text-yellow-500 border-yellow-500/30">Pending</span>
    <% when "processed" %>
      <span class="badge bg-blue-500/10 text-blue-500 border-blue-500/30">Processed</span>
    <% when "evaluating" %>
      <span class="badge bg-primary/10 text-primary border-primary/30">Evaluating...</span>
    <% when "evaluated" %>
      <span class="badge bg-emerald-500/10 text-emerald-500 border-emerald-500/30">Evaluated</span>
    <% end %>
  </div>

  <div class="grid grid-cols-2 md:grid-cols-5 gap-4 text-sm">
    <div>
      <p class="text-muted">Transactions</p>
      <p class="text-heading font-bold text-lg"><%= @upload.transaction_count %></p>
    </div>
    <div>
      <p class="text-muted">Unique Transactions</p>
      <p class="text-heading font-bold text-lg"><%= @upload.unique_transactions %></p>
    </div>
    <div>
      <p class="text-muted">Duplicates Skipped</p>
      <p class="text-heading font-bold text-lg"><%= @upload.duplicates_skipped %></p>
    </div>
    <div>
      <p class="text-muted">Credits Skipped</p>
      <p class="text-heading font-bold text-lg"><%= @upload.credits_skipped %></p>
    </div>
    <% if @upload.evaluated? %>
      <div>
        <p class="text-muted">Needs Review</p>
        <p class="text-heading font-bold text-lg"><%= @upload.expense_transactions.needs_review.count %></p>
      </div>
    <% end %>
  </div>

  <% if @upload.processing_summary.present? && @upload.processing_summary["errors"].present? %>
    <div class="mt-4 p-3 rounded-lg bg-red-500/10 border border-red-500/30 text-sm">
      <p class="font-bold text-red-400 mb-1">Processing Errors:</p>
      <ul class="text-red-300 space-y-1">
        <% @upload.processing_summary["errors"].each do |error| %>
          <li><%= error %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
</div>

<%# Transactions Table %>
<% if @transactions.any? %>
  <div class="card overflow-hidden">
    <table class="w-full text-sm">
      <thead>
        <tr class="bg-surface-alt text-muted text-left">
          <th class="px-4 py-3 font-medium">Date</th>
          <th class="px-4 py-3 font-medium">Description</th>
          <th class="px-4 py-3 font-medium text-right">Amount</th>
          <th class="px-4 py-3 font-medium">Status</th>
          <th class="px-4 py-3 font-medium">Category</th>
          <th class="px-4 py-3 font-medium">Account</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-subtle">
        <% @transactions.each do |txn| %>
          <tr class="hover:bg-surface-alt/50 transition">
            <td class="px-4 py-3 text-secondary"><%= txn.transaction_date.strftime("%m/%d/%y") %></td>
            <td class="px-4 py-3">
              <%= link_to expense_transaction_path(txn.slug), class: "text-heading hover:text-primary transition" do %>
                <span class="font-medium"><%= txn.vendor || truncate(txn.raw_description, length: 50) %></span>
              <% end %>
            </td>
            <td class="px-4 py-3 text-right font-mono text-heading"><%= txn.formatted_amount %></td>
            <td class="px-4 py-3">
              <%= render "expense_transactions/status_badge", txn: txn %>
            </td>
            <td class="px-4 py-3 text-secondary"><%= txn.category_display %></td>
            <td class="px-4 py-3 text-secondary"><%= txn.account_display %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="empty-state">
    <p class="text-secondary">No transactions yet. Process the file to extract transactions.</p>
  </div>
<% end %>

