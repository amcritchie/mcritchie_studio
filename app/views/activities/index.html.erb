<% agent_avatars = @agents.index_by(&:slug).transform_values(&:avatar) %>

<section>
  <div class="flex items-center justify-between mb-6">
    <h2 class="text-2xl font-bold text-heading">Activity Feed</h2>
    <div class="flex items-center gap-2">
      <% if params[:agent].present? %>
        <%= link_to "Clear filter", activities_path, class: "text-xs text-secondary hover:text-heading transition" %>
      <% end %>
    </div>
  </div>

  <% if @activities.any? %>
    <div class="space-y-2">
      <% @activities.each do |activity| %>
        <div class="card p-4 flex items-center justify-between">
          <div class="flex items-center gap-3 flex-1 min-w-0">
            <%= render "components/badge", text: activity.activity_type, scheme: "violet" %>
            <span class="text-sm text-body truncate"><%= activity.description %></span>
            <% if activity.agent_slug.present? %>
              <%= link_to agent_path(activity.agent_slug), class: "flex items-center gap-1 shrink-0 hover:opacity-80 transition" do %>
                <% if agent_avatars[activity.agent_slug].present? %>
                  <img src="<%= agent_avatars[activity.agent_slug] %>" alt="<%= activity.agent_slug %>" class="w-5 h-5 rounded-full object-cover">
                <% else %>
                  <div class="w-5 h-5 rounded-full bg-primary/20 flex items-center justify-center">
                    <span class="text-primary text-[9px] font-bold"><%= activity.agent_slug.first.upcase %></span>
                  </div>
                <% end %>
                <span class="text-xs text-primary"><%= activity.agent_slug %></span>
              <% end %>
            <% end %>
            <% if activity.task_slug.present? %>
              <%= link_to activity.task_slug, task_path(activity.task_slug), class: "text-xs text-primary hover:text-primary-300 shrink-0" %>
            <% end %>
          </div>
          <span class="text-xs text-muted shrink-0 ml-3"><%= time_ago_in_words(activity.created_at) %> ago</span>
        </div>
      <% end %>
    </div>
  <% else %>
    <%= render "components/empty_state", message: "No activity recorded yet." %>
  <% end %>
</section>
