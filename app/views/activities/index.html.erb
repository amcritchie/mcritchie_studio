<section>
  <div class="flex items-center justify-between mb-6">
    <h2 class="text-2xl font-bold text-white">Activity Feed</h2>
    <div class="flex items-center gap-2">
      <% if params[:agent].present? %>
        <%= link_to "Clear filter", activities_path, class: "text-xs text-gray-400 hover:text-white transition" %>
      <% end %>
    </div>
  </div>

  <% if @activities.any? %>
    <div class="space-y-2">
      <% @activities.each do |activity| %>
        <div class="card p-4 flex items-center justify-between">
          <div class="flex items-center gap-3 flex-1 min-w-0">
            <%= render "components/badge", text: activity.activity_type, scheme: "violet" %>
            <span class="text-sm text-gray-300 truncate"><%= activity.description %></span>
            <% if activity.agent_slug.present? %>
              <%= link_to activity.agent_slug, agent_path(activity.agent_slug), class: "text-xs text-violet hover:text-violet-300 shrink-0" %>
            <% end %>
            <% if activity.task_slug.present? %>
              <%= link_to activity.task_slug, task_path(activity.task_slug), class: "text-xs text-violet hover:text-violet-300 shrink-0" %>
            <% end %>
          </div>
          <span class="text-xs text-gray-600 shrink-0 ml-3"><%= time_ago_in_words(activity.created_at) %> ago</span>
        </div>
      <% end %>
    </div>
  <% else %>
    <%= render "components/empty_state", message: "No activity recorded yet." %>
  <% end %>
</section>
