<section>
  <div class="flex items-center justify-between mb-6">
    <h2 class="text-2xl font-bold text-white">Activity Feed</h2>
    <div class="flex items-center gap-2">
      <% if params[:agent].present? %>
        <%= link_to "Clear filter", activities_path, class: "text-xs text-gray-400 hover:text-white transition" %>
      <% end %>
    </div>
  </div>

  <% if @activities.any? %>
    <div class="space-y-2">
      <% @activities.each do |activity| %>
        <div class="bg-navy-400 rounded-xl border border-navy-300/20 p-4 flex items-center justify-between">
          <div class="flex items-center gap-3 flex-1 min-w-0">
            <span class="inline-flex items-center px-2 py-0.5 bg-violet-900/30 border border-violet-700/50 rounded text-xs text-violet-300 shrink-0"><%= activity.activity_type %></span>
            <span class="text-sm text-gray-300 truncate"><%= activity.description %></span>
            <% if activity.agent_slug.present? %>
              <%= link_to activity.agent_slug, agent_path(activity.agent_slug), class: "text-xs text-mint hover:text-mint-300 shrink-0" %>
            <% end %>
            <% if activity.task_slug.present? %>
              <%= link_to activity.task_slug, task_path(activity.task_slug), class: "text-xs text-violet hover:text-violet-300 shrink-0" %>
            <% end %>
          </div>
          <span class="text-xs text-gray-600 shrink-0 ml-3"><%= time_ago_in_words(activity.created_at) %> ago</span>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="bg-navy-400 rounded-xl border border-navy-300/20 p-8 text-center">
      <p class="text-gray-400 text-lg">No activity recorded yet.</p>
    </div>
  <% end %>
</section>
