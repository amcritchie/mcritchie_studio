<% if txn.excluded %>
  <span class="badge bg-gray-500/10 text-gray-400 border-gray-500/30">Excluded</span>
<% else %>
  <% case txn.status %>
  <% when "unreviewed" %>
    <span class="badge bg-yellow-500/10 text-yellow-500 border-yellow-500/30">Unreviewed</span>
  <% when "classified" %>
    <% if txn.business_expense? %>
      <span class="badge bg-emerald-500/10 text-emerald-500 border-emerald-500/30">Business</span>
    <% else %>
      <span class="badge bg-gray-500/10 text-gray-400 border-gray-500/30">Personal</span>
    <% end %>
  <% when "needs_review" %>
    <span class="badge bg-orange-500/10 text-orange-500 border-orange-500/30">Needs Review</span>
  <% end %>
<% end %>
