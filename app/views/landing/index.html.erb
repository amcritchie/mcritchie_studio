<% content_for(:title, "McRitchie Studio — Software For Business") %>
<% content_for(:full_width, true) %>

<!-- Hero -->
<section class="relative overflow-hidden"
         style="background: linear-gradient(135deg, var(--color-primary-900, #1a1035) 0%, var(--color-surface) 50%, var(--color-primary-900, #1a1035) 100%);">
  <div class="absolute inset-0 opacity-20"
       style="background: radial-gradient(circle at 25% 50%, var(--color-primary-500) 0%, transparent 50%),
              radial-gradient(circle at 75% 30%, var(--color-primary-700) 0%, transparent 45%);"></div>
  <div class="relative z-10 max-w-4xl mx-auto px-4 text-center" style="padding: 8rem 1rem;">
    <h1 class="font-extrabold text-heading tracking-tight mb-6 flex items-baseline justify-center" style="font-size: clamp(2.5rem, 6vw, 4.5rem); line-height: 1.1; gap: 0.3em;">
      Software For
      <span class="dropping-texts text-primary" data-spacer="Business">
        <span>Business</span>
        <span>Agents</span>
        <span>People</span>
      </span>
    </h1>
    <p class="text-secondary max-w-2xl mx-auto mb-10 leading-relaxed" style="font-size: clamp(1.1rem, 2.5vw, 1.5rem);">
      Tired of putting out fires? I bring a decade of product and software
      experience to super charge your team.
    </p>
    <a href="#about" class="btn btn-primary btn-lg">Meet Alex</a>
  </div>
</section>

<!-- About -->
<section id="about" class="max-w-4xl mx-auto px-4" style="padding: 5rem 1rem;">
  <div class="text-center mb-12">
    <h2 class="text-4xl font-extrabold text-heading mb-2">Alex McRitchie</h2>
    <p class="text-primary text-lg font-semibold uppercase tracking-wider">Who Am I?</p>
    <p class="text-secondary mt-4 max-w-2xl mx-auto text-lg leading-relaxed">
      Ten years experience in operational &amp; engineering leadership
      in companies between $5M &ndash; $10M in revenue.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="card p-6">
      <div class="text-2xl mb-3">&#x1F91D;</div>
      <h3 class="text-heading font-bold text-lg mb-2">Business Development</h3>
      <p class="text-secondary">Building and scaling revenue through strategic partnerships and market positioning.</p>
    </div>
    <div class="card p-6">
      <div class="text-2xl mb-3">&#x1F916;</div>
      <h3 class="text-heading font-bold text-lg mb-2">Technical Strategy &amp; Execution</h3>
      <p class="text-secondary">10 years software engineering, 10 years product. From architecture to delivery.</p>
    </div>
    <div class="card p-6">
      <div class="text-2xl mb-3">&#x1F39B;&#xFE0F;</div>
      <h3 class="text-heading font-bold text-lg mb-2">Operating Excellence</h3>
      <p class="text-secondary">Streamlining operations to maximize efficiency and minimize waste.</p>
    </div>
    <div class="card p-6">
      <div class="text-2xl mb-3">&#x1F52E;</div>
      <h3 class="text-heading font-bold text-lg mb-2">Leadership &amp; Vision</h3>
      <p class="text-secondary">Guiding teams toward ambitious goals with clarity and purpose.</p>
    </div>
  </div>
</section>

<!-- Acquisition Criteria -->
<section class="bg-surface-alt border-t border-b border-subtle">
  <div class="max-w-4xl mx-auto px-4" style="padding: 5rem 1rem;">
    <div class="text-center mb-12">
      <h2 class="text-4xl font-extrabold text-heading mb-2">Is This Your Business?</h2>
      <p class="text-secondary text-lg">I'm looking for established companies ready for their next chapter.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="card p-8 text-center">
        <div class="text-primary font-extrabold mb-3" style="font-size: 1.75rem;">B2B SaaS</div>
        <p class="text-secondary">with loyal customers</p>
      </div>
      <div class="card p-8 text-center">
        <div class="text-primary font-extrabold mb-3" style="font-size: 1.75rem;">$400K &ndash; $1M</div>
        <p class="text-secondary">annual revenue</p>
      </div>
      <div class="card p-8 text-center">
        <div class="text-primary font-extrabold mb-3" style="font-size: 1.75rem;">10+ Years</div>
        <p class="text-secondary">in business</p>
      </div>
    </div>
  </div>
</section>

<!-- Contact -->
<section class="max-w-3xl mx-auto px-4 text-center" style="padding: 5rem 1rem;">
  <h2 class="text-4xl font-extrabold text-heading mb-4">Get In Touch</h2>
  <p class="text-secondary text-lg mb-10">Interested in connecting? Reach out through any of the channels below.</p>

  <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
    <a href="mailto:alex@mcritchie.studio" class="btn btn-primary btn-lg">
      alex@mcritchie.studio
    </a>
    <a href="https://www.linkedin.com/in/alexmcritchie/" target="_blank" rel="noopener" class="btn btn-outline btn-lg">
      LinkedIn
    </a>
    <a href="https://x.com/alexmcritchie" target="_blank" rel="noopener" class="btn btn-outline btn-lg">
      X
    </a>
  </div>

  <p class="text-muted text-sm mt-8">3010 Humboldt St, Denver, CO 80205</p>
</section>
