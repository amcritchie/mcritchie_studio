<section>
  <h2 class="text-2xl font-bold text-heading mb-6">Usage</h2>

  <% if @usages.any? %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-subtle">
            <th class="text-left text-muted text-xs uppercase tracking-wider py-3 px-3">Agent</th>
            <th class="text-left text-muted text-xs uppercase tracking-wider py-3 px-3">Date</th>
            <th class="text-left text-muted text-xs uppercase tracking-wider py-3 px-3">Period</th>
            <th class="text-left text-muted text-xs uppercase tracking-wider py-3 px-3">Model</th>
            <th class="text-right text-muted text-xs uppercase tracking-wider py-3 px-3">Tokens In</th>
            <th class="text-right text-muted text-xs uppercase tracking-wider py-3 px-3">Tokens Out</th>
            <th class="text-right text-muted text-xs uppercase tracking-wider py-3 px-3">API Calls</th>
            <th class="text-right text-muted text-xs uppercase tracking-wider py-3 px-3">Cost</th>
          </tr>
        </thead>
        <tbody>
          <% @usages.each do |usage| %>
            <tr class="border-b border-subtle/50 hover:bg-surface/50">
              <td class="py-3 px-3 text-primary"><%= usage.agent_slug %></td>
              <td class="py-3 px-3 text-body"><%= usage.period_date %></td>
              <td class="py-3 px-3 text-secondary"><%= usage.period_type %></td>
              <td class="py-3 px-3 text-secondary font-mono text-xs"><%= usage.model %></td>
              <td class="py-3 px-3 text-body text-right"><%= number_with_delimiter(usage.tokens_in) %></td>
              <td class="py-3 px-3 text-body text-right"><%= number_with_delimiter(usage.tokens_out) %></td>
              <td class="py-3 px-3 text-body text-right"><%= usage.api_calls %></td>
              <td class="py-3 px-3 text-primary text-right font-mono">$<%= sprintf('%.4f', usage.cost) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <%= render "components/empty_state", message: "No usage data yet." %>
  <% end %>
</section>
