<section>
  <h2 class="text-2xl font-bold text-white mb-6">Usage</h2>

  <% if @usages.any? %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-navy-300/20">
            <th class="text-left text-gray-500 text-xs uppercase tracking-wider py-3 px-3">Agent</th>
            <th class="text-left text-gray-500 text-xs uppercase tracking-wider py-3 px-3">Date</th>
            <th class="text-left text-gray-500 text-xs uppercase tracking-wider py-3 px-3">Period</th>
            <th class="text-left text-gray-500 text-xs uppercase tracking-wider py-3 px-3">Model</th>
            <th class="text-right text-gray-500 text-xs uppercase tracking-wider py-3 px-3">Tokens In</th>
            <th class="text-right text-gray-500 text-xs uppercase tracking-wider py-3 px-3">Tokens Out</th>
            <th class="text-right text-gray-500 text-xs uppercase tracking-wider py-3 px-3">API Calls</th>
            <th class="text-right text-gray-500 text-xs uppercase tracking-wider py-3 px-3">Cost</th>
          </tr>
        </thead>
        <tbody>
          <% @usages.each do |usage| %>
            <tr class="border-b border-navy-300/10 hover:bg-navy-400/50">
              <td class="py-3 px-3 text-mint"><%= usage.agent_slug %></td>
              <td class="py-3 px-3 text-gray-300"><%= usage.period_date %></td>
              <td class="py-3 px-3 text-gray-400"><%= usage.period_type %></td>
              <td class="py-3 px-3 text-gray-400 font-mono text-xs"><%= usage.model %></td>
              <td class="py-3 px-3 text-gray-300 text-right"><%= number_with_delimiter(usage.tokens_in) %></td>
              <td class="py-3 px-3 text-gray-300 text-right"><%= number_with_delimiter(usage.tokens_out) %></td>
              <td class="py-3 px-3 text-gray-300 text-right"><%= usage.api_calls %></td>
              <td class="py-3 px-3 text-mint text-right font-mono">$<%= sprintf('%.4f', usage.cost) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="bg-navy-400 rounded-xl border border-navy-300/20 p-8 text-center">
      <p class="text-gray-400 text-lg">No usage data yet.</p>
    </div>
  <% end %>
</section>
