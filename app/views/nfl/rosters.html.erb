<style>
  .roster-spot   { position: relative; }
  .roster-img    {
    display: block;
    transition: transform 0.15s ease;
    transform-origin: center;
  }
  .roster-spot:hover .roster-img {
    transform: scale(2.8);
    z-index: 20;
    position: relative;
  }
  .roster-name {
    position: absolute;
    top: calc(100% + 4.5rem);
    left: 50%;
    transform: translateX(-50%);
    opacity: 0;
    pointer-events: none;
    white-space: nowrap;
    z-index: 30;
    transition: opacity 0.15s ease;
  }
  .roster-spot:hover .roster-name { opacity: 1; }
  /* Position badge — always visible bottom-right corner of the headshot */
  .roster-badge {
    position: absolute;
    bottom: -2px;
    right: -2px;
    min-width: 1.1rem;
    height: 1.1rem;
    padding: 0 0.25rem;
    border-radius: 0.55rem;
    background: rgba(15, 12, 35, 0.92);
    color: #fff;
    font-size: 9px;
    font-weight: 700;
    line-height: 1.1rem;
    text-align: center;
    z-index: 10;
    pointer-events: none;
    border: 1.5px solid rgba(255, 255, 255, 0.15);
    letter-spacing: 0.02em;
  }
</style>

<script>
  document.addEventListener("mouseover", (e) => {
    const img = e.target.closest(".roster-img[data-hover-src]");
    if (!img) return;
    if (!img.dataset.defaultSrc) img.dataset.defaultSrc = img.src;
    if (img.src !== img.dataset.hoverSrc) img.src = img.dataset.hoverSrc;
  });
  document.addEventListener("mouseout", (e) => {
    const img = e.target.closest(".roster-img[data-hover-src]");
    if (!img || !img.dataset.defaultSrc) return;
    if (img.src !== img.dataset.defaultSrc) img.src = img.dataset.defaultSrc;
  });
</script>

<%# Slot labels come from LineupLabelsHelper — shared with /teams/:slug/depth-chart %>

<section class="max-w-7xl mx-auto px-4 py-8">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-heading mb-2">NFL Rosters</h1>
    <p class="text-secondary text-sm">Each team's starting offense (12), defense (12), special teams (4), and coaching staff (4). Headshots when available.</p>
  </div>

  <div class="space-y-4">
    <% @rosters.each do |roster| %>
      <% team = roster.team %>
      <div class="card p-4">
        <div class="flex items-center justify-between mb-3 gap-3">
          <%= link_to team_depth_chart_path(team.slug), class: "flex items-center gap-2 hover:text-primary transition" do %>
            <% if team.color_primary.present? %>
              <span class="inline-block w-3 h-3 rounded-full flex-shrink-0" style="background-color: <%= team.color_primary %>"></span>
            <% end %>
            <h2 class="text-heading font-semibold"><%= team.emoji %> <%= team.name %></h2>
            <span class="text-muted text-xs">→ depth chart</span>
          <% end %>
          <div class="flex items-center gap-2">
            <%= link_to "👀 Preview", team_lineup_graphic_path(team.slug),
                  class: "btn btn-outline btn-sm", target: "_blank" %>
            <%= button_to "🐦 New X Post", starter_post_x_contents_path(team_slug: team.slug),
                  class: "btn btn-primary btn-sm", form: { class: "inline-block" } %>
          </div>
        </div>

        <%
          off_pairs = roster.offense_starting_12.map { |slot, pick| [offense_slot_label(slot, pick), pick] }
          def_pairs = roster.defense_starting_12.map { |slot, pick| [defense_slot_label(slot, pick), pick] }
          st_picks  = roster.special_teams_starting_4.values.flatten.compact
          st_pairs  = st_picks.map { |p| [p.position.to_s, p] }
          coaches   = @coaches_by_team[team.slug] || []
          coach_pairs = coaches.map { |c| [c.role.split("_").map { |w| w[0].upcase }.join, c] }
        %>

        <% rows = [
          ["O", off_pairs, :spot],
          ["D", def_pairs, :spot],
          ["S", st_pairs,  :spot],
          ["C", coach_pairs, :coach]
        ] %>
        <% rows.each do |label, items, kind| %>
          <div class="flex items-start gap-2 mb-2 last:mb-0">
            <span class="w-5 text-xs text-muted font-mono uppercase pt-3"><%= label %></span>
            <div class="flex flex-wrap gap-1">
              <% items.each do |slot_label, item| %>
                <% if item.nil? %>
                  <div class="roster-spot relative">
                    <div class="roster-img w-12 h-12 rounded-full bg-surface-alt flex items-center justify-center text-[10px] text-muted font-mono opacity-40">
                      <%= slot_label %>
                    </div>
                  </div>
                <% else %>
                  <% if kind == :spot %>
                    <% person  = item.person %>
                    <% athlete = person&.athlete_profile %>
                    <% small   = athlete&.headshot_url(width: 100) %>
                    <% large   = athlete&.headshot_url(width: 400) %>
                  <% else %>
                    <% person = item.person %>
                    <% small  = item.headshot_url(width: 100) %>
                    <% large  = item.headshot_url(width: 400) %>
                  <% end %>
                  <div class="roster-spot relative">
                    <% if small %>
                      <img src="<%= small %>"
                           data-hover-src="<%= large %>"
                           alt="<%= person&.full_name %>"
                           loading="lazy"
                           class="roster-img w-12 h-12 rounded-full object-cover bg-surface-alt">
                    <% else %>
                      <div class="roster-img w-12 h-12 rounded-full bg-surface-alt flex items-center justify-center text-[10px] text-muted font-mono">
                        <%= slot_label %>
                      </div>
                    <% end %>
                    <span class="roster-badge"><%= slot_label %></span>
                    <span class="roster-name px-2 py-1 bg-inset text-heading text-[11px] font-medium rounded shadow-lg">
                      <%= person&.full_name %><span class="text-muted ml-1">· <%= slot_label %></span>
                    </span>
                  </div>
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</section>
