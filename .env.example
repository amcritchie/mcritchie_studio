# McRitchie Studio — environment variables
# Copy to .env and fill in. See docs/agents/system/credentials.md for the canonical
# 1Password / Heroku locations for each value.

# ───── Required to boot ─────
RAILS_MASTER_KEY=                 # heroku config:get RAILS_MASTER_KEY --app mcritchie-studio

# ───── Google OAuth (login + admin gear) ─────
GOOGLE_CLIENT_ID=                 # Google Cloud Console — OAuth client
GOOGLE_CLIENT_SECRET=

# ───── Claude API (AI chat, News refine/conclude agents, Content metadata) ─────
ANTHROPIC_API_KEY=                # 1Password: "anthropic" in agents vault

# ───── X / Twitter API ─────
# Read-only (News intake from @AdamSchefter tweets)
X_BEARER_TOKEN=                   # 1Password: "x.api" (Bearer Token field)

# Read+Write (Starter Post X workflow — posting from @turfmonstershow)
# IMPORTANT: must be from an X app with "Read and Write" permissions
X_API_KEY=                        # 1Password: "x.api"
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# ───── Higgsfield (image/video generation: Nano Banana + Kling 3) ─────
HIGGSFIELD_API_KEY=               # 1Password: "agent.higgesfield" in agents vault
HIGGSFIELD_API_SECRET=

# ───── TikTok Content Posting API (Starter Post TikTok workflows) ─────
# App is in review (submitted 2026-05-04). Sandbox mode works for app owner only.
TIKTOK_CLIENT_KEY=                # 1Password: "🐊 TikTok" in agents vault
TIKTOK_CLIENT_SECRET=
TIKTOK_REFRESH_TOKEN=             # From /admin/tiktok/connect handshake — see CLAUDE.md
TIKTOK_OPEN_ID=

# ───── AWS S3 (ImageCache via studio engine) ─────
# Bucket: mcritchie-studio-{dev,production}
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
